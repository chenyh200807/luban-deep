/* pages/index/index.wxss */
.container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.close-btn {
  position: absolute;
  bottom: 27%;
  width: 80px;
}

.close-btn image {
  width: 100%;
  height: 34px;
}


/* 在小程序页面的wxss文件中 */
.left-top {
  position: absolute;
  top: 0;
  left: 0;
  width: 50%; /* 根据需要调整宽度 */
  height: 100%; /* 根据需要调整高度 */
  /* background-color: rgb(65, 0, 109); */
    /* transform: rotate(45deg); */
}

.right-bottom {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 50%; /* 根据需要调整宽度 */
  height: 100%; /* 根据需要调整高度 */
  /* background-color: red; */
    /* transform: rotate(45deg); */
}

.left-right-top{
  width: 150%;
  height: 120%;
  position: absolute;
  transform: rotate(50deg);
  top: -17%;
}

.icon {
  position: fixed;
  bottom: 20px;
  /* right: 20px; */
  width: 50px;
  height: 50px;
  background-color: #269038;
  border-radius: 50%;
  text-align: center;
  line-height: 50px;
  font-size: 24px;
  color: #fff;
  cursor: pointer;
}
