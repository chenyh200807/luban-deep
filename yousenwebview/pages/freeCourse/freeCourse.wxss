page {
  height: 100%;
  background: linear-gradient(180deg, #f8f4ee 0%, #f4efe7 100%);
}

.yousen-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(12, 31, 58, 0.04) 0%, transparent 30%),
    radial-gradient(circle at right 20%, rgba(180, 141, 73, 0.08) 0%, transparent 26%);
}

.page-scroll {
  height: 100vh;
}

.page-shell {
  padding: 28rpx 24rpx 0;
}

.hero-card {
  padding: 34rpx 30rpx 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 252, 247, 0.96);
  border: 1rpx solid rgba(12, 31, 58, 0.08);
  box-shadow: 0 20rpx 56rpx rgba(37, 29, 18, 0.06);
}

.hero-topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-brand-group {
  display: flex;
  align-items: center;
}

.hero-brand-mark {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  background: #10233c;
  color: #f8f2e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero-brand-copy {
  margin-left: 18rpx;
  display: flex;
  flex-direction: column;
}

.hero-brand-name {
  font-size: 38rpx;
  line-height: 1.1;
  color: #10233c;
  font-weight: 700;
}

.hero-brand-sub {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: rgba(16, 35, 60, 0.56);
}

.hero-label {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(181, 141, 73, 0.1);
  color: #8b6a2f;
  font-size: 20rpx;
  font-weight: 600;
  white-space: nowrap;
}

.hero-eyebrow {
  display: block;
  margin-top: 34rpx;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: rgba(16, 35, 60, 0.48);
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 54rpx;
  line-height: 1.14;
  color: #10233c;
  font-weight: 700;
}

.hero-subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 1.72;
  color: rgba(16, 35, 60, 0.68);
}

.direction-picker {
  display: block;
  margin-top: 28rpx;
}

.direction-picker-inner {
  min-height: 112rpx;
  padding: 24rpx 24rpx;
  border-radius: 24rpx;
  background: #f7f2eb;
  border: 1rpx solid rgba(16, 35, 60, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.direction-picker-copy {
  display: flex;
  flex-direction: column;
}

.direction-picker-label {
  font-size: 20rpx;
  color: rgba(16, 35, 60, 0.46);
}

.direction-picker-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1.35;
  color: #10233c;
  font-weight: 600;
}

.direction-picker-icon {
  width: 40rpx;
  height: 40rpx;
}

.rotate-image {
  transition: transform 0.25s ease;
}

.hero-stats {
  margin-top: 26rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(16, 35, 60, 0.08);
  display: flex;
}

.hero-stat {
  flex: 1;
}

.hero-stat + .hero-stat {
  padding-left: 18rpx;
  border-left: 1rpx solid rgba(16, 35, 60, 0.08);
}

.hero-stat-value {
  display: block;
  font-size: 30rpx;
  line-height: 1;
  color: #10233c;
  font-weight: 700;
}

.hero-stat-label {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: rgba(16, 35, 60, 0.52);
}

.assistant-panel {
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 249, 240, 0.96);
  border: 1rpx solid rgba(181, 141, 73, 0.16);
  box-shadow: 0 14rpx 36rpx rgba(37, 29, 18, 0.04);
  display: flex;
  align-items: center;
}

.assistant-mark {
  width: 66rpx;
  height: 66rpx;
  border-radius: 18rpx;
  background: #10233c;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.assistant-copy {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.assistant-title {
  display: block;
  font-size: 28rpx;
  color: #10233c;
  font-weight: 700;
}

.assistant-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(16, 35, 60, 0.62);
}

.assistant-arrow {
  font-size: 38rpx;
  line-height: 1;
  color: rgba(16, 35, 60, 0.4);
  margin-left: 14rpx;
}

.section-head {
  margin-top: 34rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.section-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 2.5rpx;
  color: rgba(16, 35, 60, 0.44);
}

.section-title {
  display: block;
  margin-top: 8rpx;
  font-size: 40rpx;
  line-height: 1.14;
  color: #10233c;
  font-weight: 700;
}

.section-meta {
  text-align: right;
  padding-bottom: 2rpx;
}

.section-meta-value {
  display: block;
  font-size: 32rpx;
  line-height: 1;
  color: #10233c;
  font-weight: 700;
}

.section-meta-label {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(16, 35, 60, 0.44);
}

.section-description {
  display: block;
  margin-top: 14rpx;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  line-height: 1.72;
  color: rgba(16, 35, 60, 0.62);
}

.course-card {
  margin-bottom: 24rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: rgba(255, 252, 247, 0.98);
  border: 1rpx solid rgba(16, 35, 60, 0.08);
  box-shadow: 0 18rpx 44rpx rgba(37, 29, 18, 0.05);
}

.course-media {
  width: 100%;
  height: 320rpx;
  display: block;
  background: #e8dfd1;
}

.course-content {
  padding: 28rpx 24rpx 24rpx;
}

.course-heading {
  display: flex;
  flex-direction: column;
}

.course-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: rgba(181, 141, 73, 0.11);
  color: #8b6a2f;
  font-size: 18rpx;
  font-weight: 600;
}

.course-title {
  display: block;
  margin-top: 14rpx;
  font-size: 34rpx;
  line-height: 1.36;
  color: #10233c;
  font-weight: 700;
}

.course-summary {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.68;
  color: rgba(16, 35, 60, 0.6);
}

.teacher-row {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
}

.teacher-avatars {
  display: flex;
  align-items: center;
}

.teacher-avatar {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  border: 3rpx solid #fffaf3;
  background: #ded4c5;
}

.teacher-avatar + .teacher-avatar {
  margin-left: -12rpx;
}

.teacher-copy {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.teacher-name,
.teacher-count {
  font-size: 22rpx;
  color: rgba(16, 35, 60, 0.54);
}

.course-footer {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.course-meta-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f3eee5;
  color: #53657a;
  font-size: 20rpx;
  font-weight: 600;
}

.course-action {
  min-width: 178rpx;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #10233c;
  display: flex;
  align-items: center;
  justify-content: center;
}

.course-action-text {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.course-empty {
  padding: 80rpx 36rpx 96rpx;
  border-radius: 30rpx;
  background: rgba(255, 252, 247, 0.92);
  border: 1rpx solid rgba(16, 35, 60, 0.08);
  text-align: center;
}

.course-empty-title {
  display: block;
  font-size: 34rpx;
  color: #10233c;
  font-weight: 700;
}

.course-empty-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(16, 35, 60, 0.56);
}

.service-banner {
  position: relative;
  overflow: hidden;
  margin-top: 14rpx;
  border-radius: 28rpx;
  background: #10233c;
}

.service-banner-image {
  width: 100%;
  height: 220rpx;
  display: block;
}

.service-banner-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(90deg, rgba(16, 35, 60, 0.7), rgba(16, 35, 60, 0.18));
}

.service-banner-copy {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 22rpx;
}

.service-banner-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.64);
  letter-spacing: 2rpx;
}

.service-banner-title {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.4;
  color: #ffffff;
  font-weight: 600;
}

.bottom-space {
  height: 80rpx;
}

.promo-modal {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
}

.promo-modal-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(2, 8, 16, 0.64);
}

.promo-modal-card {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 620rpx;
  transform: translate(-50%, -50%);
}

.promo-modal-figure {
  position: relative;
  width: 100%;
  min-height: 240rpx;
}

.promo-modal-image {
  width: 100%;
  display: block;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.22);
}

.promo-modal-hitbox {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  bottom: 0;
  transform: rotate(50deg) scale(1.15);
  z-index: 2;
}

.promo-hit-left,
.promo-hit-right {
  position: absolute;
  top: 0;
  width: 50%;
  height: 100%;
}

.promo-hit-left {
  left: 0;
}

.promo-hit-right {
  right: 0;
}

.promo-modal-close {
  position: relative;
  z-index: 5;
  width: 64rpx;
  height: 64rpx;
  margin: 24rpx auto 0;
}

.promo-modal-close image {
  width: 100%;
  height: 100%;
}

.promo-modal-loading {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  z-index: 3;
  display: flex;
  justify-content: center;
  pointer-events: none;
}

.promo-modal-loading-text {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(7, 17, 31, 0.7);
  color: #ffffff;
  font-size: 22rpx;
}
