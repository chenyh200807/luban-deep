page {
  height: 100%;
  background: #ffffff;
}

.yousen-page {
  min-height: 100vh;
  background: #ffffff;
}

.cover-hero {
  position: fixed;
  top: 0;
  right: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  min-height: 980rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 16% 12%, rgba(255, 255, 255, 0.16) 0%, transparent 34%),
    radial-gradient(circle at 88% 18%, rgba(255, 255, 255, 0.12) 0%, transparent 26%),
    linear-gradient(135deg, #13243a 0%, #1f3a57 48%, #d7dee7 100%);
  z-index: 1;
}

.cover-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background:
    linear-gradient(90deg, rgba(6, 17, 31, 0.50) 0%, rgba(6, 17, 31, 0.14) 42%, rgba(6, 17, 31, 0.06) 100%),
    linear-gradient(180deg, rgba(6, 17, 31, 0.10) 0%, rgba(6, 17, 31, 0.34) 100%);
}

.cover-glow {
  position: absolute;
  top: -120rpx;
  left: -140rpx;
  width: 520rpx;
  height: 520rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.26) 0%, transparent 72%);
  filter: blur(10rpx);
  opacity: 0.72;
}

.hero-inner {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  top: 108rpx;
  z-index: 3;
}

.hero-brand-block {
  max-width: 460rpx;
  animation: heroLiftIn 640ms cubic-bezier(0.22, 1, 0.36, 1);
}

.hero-brand-row {
  display: flex;
  align-items: flex-end;
}

.hero-brand-copy {
  display: flex;
  flex-direction: column;
  padding-bottom: 10rpx;
}

.hero-brand-name {
  font-size: 60rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-brand-slogan {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.5;
  letter-spacing: 1.4rpx;
  color: rgba(255, 255, 255, 0.78);
}

.hero-anniversary-panel {
  position: absolute;
  right: 24rpx;
  top: 296rpx;
  width: 248rpx;
  min-height: 264rpx;
  opacity: 0;
  transform-origin: 100% 40%;
}

.hero-anniversary-watermark {
  position: absolute;
  right: 0;
  top: 0;
  font-size: 196rpx;
  line-height: 0.8;
  letter-spacing: -16rpx;
  color: rgba(255, 255, 255, 0.2);
  font-weight: 700;
}

.hero-anniversary-copy {
  position: relative;
  z-index: 1;
  padding-top: 72rpx;
  text-align: right;
}

.hero-anniversary-date {
  display: block;
  font-size: 21rpx;
  letter-spacing: 3rpx;
  color: rgba(255, 255, 255, 0.56);
}

.hero-anniversary-title {
  display: block;
  margin-top: 16rpx;
  font-size: 40rpx;
  letter-spacing: 10rpx;
  color: rgba(255, 255, 255, 0.96);
  font-weight: 500;
}

.hero-anniversary-meta {
  display: block;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.18);
  font-size: 20rpx;
  line-height: 1.5;
  letter-spacing: 1.4rpx;
  color: rgba(255, 255, 255, 0.74);
}

.hero-primary-btn,
.hero-secondary-btn {
  min-width: 184rpx;
  height: 82rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-primary-btn {
  background: #ffffff;
}

.hero-primary-btn-text {
  font-size: 26rpx;
  color: #10233c;
  font-weight: 700;
}

.hero-ai-bridge {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 28rpx 28rpx 36rpx;
  padding: 18rpx 18rpx 18rpx 18rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(16, 35, 60, 0.06);
  box-shadow: 0 20rpx 46rpx rgba(9, 20, 35, 0.12);
}

.hero-ai-bridge-mark {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: #10233c;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.hero-ai-bridge-copy {
  flex: 1;
  min-width: 0;
}

.hero-ai-bridge-title {
  display: block;
  font-size: 26rpx;
  color: #10233c;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.hero-ai-bridge-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: rgba(16, 35, 60, 0.5);
}

.hero-ai-bridge-cta {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 8rpx 8rpx 22rpx;
  border-radius: 999rpx;
  background: #10233c;
  border: 1rpx solid rgba(16, 35, 60, 0.04);
  flex-shrink: 0;
}

.hero-ai-bridge-cta-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 0.6rpx;
}

.hero-ai-bridge-cta-arrow {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(4, 10, 18, 0.14);
}

.hero-ai-bridge-cta-arrow-text {
  font-size: 30rpx;
  line-height: 1;
  color: #0f223b;
}

.content-sheet {
  position: relative;
  z-index: 4;
  margin-top: calc(100vh - 150rpx);
  min-height: 100vh;
  padding: 20rpx 32rpx 0;
  background: #ffffff;
  border-radius: 42rpx 42rpx 0 0;
}

.sheet-topline {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 2rpx;
}

.sheet-copy {
  min-width: 0;
  flex: 1;
}

.sheet-label {
  display: block;
  font-size: 20rpx;
  letter-spacing: 2.6rpx;
  color: rgba(16, 35, 60, 0.38);
}

.sheet-title {
  display: block;
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 1.12;
  color: #10233c;
  font-weight: 700;
}

.direction-picker {
  display: block;
  flex-shrink: 0;
}

.direction-picker-inner {
  min-width: 196rpx;
  height: 78rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid rgba(16, 35, 60, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.direction-picker-value {
  font-size: 22rpx;
  color: #10233c;
  font-weight: 600;
}

.direction-picker-icon {
  width: 36rpx;
  height: 36rpx;
}

.rotate-image {
  transition: transform 0.25s ease;
}

.sheet-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: rgba(16, 35, 60, 0.58);
}

.course-section {
  margin-top: 34rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 32rpx;
  color: #10233c;
  font-weight: 700;
}

.section-count {
  font-size: 22rpx;
  color: rgba(16, 35, 60, 0.42);
}

.course-row {
  display: flex;
  gap: 20rpx;
  padding: 26rpx 0;
  border-bottom: 1rpx solid rgba(16, 35, 60, 0.08);
}

.course-thumb {
  width: 232rpx;
  height: 168rpx;
  border-radius: 20rpx;
  background: #e6ebf2;
  flex-shrink: 0;
}

.course-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.course-title {
  display: block;
  font-size: 30rpx;
  line-height: 1.4;
  color: #10233c;
  font-weight: 700;
}

.course-summary {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.62;
  color: rgba(16, 35, 60, 0.56);
}

.course-meta-row {
  margin-top: auto;
  padding-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.teacher-row {
  display: flex;
  align-items: center;
  min-width: 0;
}

.teacher-avatars {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.teacher-avatar {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  background: #dfe5ec;
}

.teacher-avatar + .teacher-avatar {
  margin-left: -10rpx;
}

.teacher-copy {
  margin-left: 14rpx;
  min-width: 0;
}

.teacher-name {
  font-size: 20rpx;
  color: rgba(16, 35, 60, 0.44);
}

.course-arrow {
  flex-shrink: 0;
  font-size: 34rpx;
  line-height: 1;
  color: rgba(16, 35, 60, 0.34);
}

.course-empty {
  padding: 72rpx 12rpx 80rpx;
  text-align: center;
}

.course-empty-title {
  display: block;
  font-size: 32rpx;
  color: #10233c;
  font-weight: 700;
}

.course-empty-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(16, 35, 60, 0.5);
}

.course-card {
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid rgba(16, 35, 60, 0.08);
  box-shadow: 0 16rpx 40rpx rgba(16, 35, 60, 0.05);
}

.course-media {
  width: 100%;
  height: 320rpx;
  display: block;
  background: #e6ebf2;
}

.course-content {
  padding: 26rpx 24rpx 24rpx;
}

.course-heading {
  display: flex;
  flex-direction: column;
}

.course-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: rgba(16, 35, 60, 0.06);
  color: #10233c;
  font-size: 18rpx;
  font-weight: 600;
}

.course-title {
  display: block;
  margin-top: 14rpx;
  font-size: 32rpx;
  line-height: 1.38;
  color: #10233c;
  font-weight: 700;
}

.course-summary {
  display: block;
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.66;
  color: rgba(16, 35, 60, 0.56);
}

.course-footer {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.course-action {
  min-width: 172rpx;
  height: 68rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #10233c;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.course-action-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 700;
}

.service-banner {
  position: relative;
  overflow: hidden;
  margin-top: 30rpx;
  border-radius: 28rpx;
  background: #10233c;
}

.service-banner-image {
  width: 100%;
  height: 220rpx;
  display: block;
}

.service-banner-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(90deg, rgba(16, 35, 60, 0.68), rgba(16, 35, 60, 0.18));
}

.service-banner-copy {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
}

.service-banner-label {
  display: block;
  font-size: 18rpx;
  letter-spacing: 2.2rpx;
  color: rgba(255, 255, 255, 0.64);
}

.service-banner-title {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.4;
  color: #ffffff;
  font-weight: 600;
}

.bottom-space {
  height: 96rpx;
}

.promo-modal {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
}

.promo-modal-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(2, 8, 16, 0.64);
}

.promo-modal-card {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 620rpx;
  transform: translate(-50%, -50%);
}

.promo-modal-figure {
  position: relative;
  width: 100%;
  min-height: 240rpx;
}

.promo-modal-image {
  width: 100%;
  display: block;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.22);
}

.promo-modal-hitbox {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  bottom: 0;
  transform: rotate(50deg) scale(1.15);
  z-index: 2;
}

.promo-hit-left,
.promo-hit-right {
  position: absolute;
  top: 0;
  width: 50%;
  height: 100%;
}

.promo-hit-left {
  left: 0;
}

.promo-hit-right {
  right: 0;
}

.promo-modal-close {
  position: relative;
  z-index: 5;
  width: 64rpx;
  height: 64rpx;
  margin: 24rpx auto 0;
}

.promo-modal-close image {
  width: 100%;
  height: 100%;
}

.promo-modal-loading {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  z-index: 3;
  display: flex;
  justify-content: center;
  pointer-events: none;
}

.promo-modal-loading-text {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(7, 17, 31, 0.7);
  color: #ffffff;
  font-size: 22rpx;
}

@keyframes heroLiftIn {
  0% {
    opacity: 0;
    transform: translateY(24rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}
