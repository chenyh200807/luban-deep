/* 浮动商店入口的样式 */
.float-shop-entry {
  position: fixed;
  left: 3rpx; /* 调整图标距离左侧的距离 */
  top: 70%;
  transform: translateY(-50%);
  width: 60rpx; /* 根据图标大小调整 */
  height: 60rpx; /* 根据图标大小调整 */
  z-index: 888; /* 确保图标在最上层 */
  animation: floatAnim 4s ease-in-out infinite;
}

/* 商店图标的样式 */
.shop-icon {
  width: 170rpx;
  height: 170rpx;
  /* height: 100%; */
  /* border-radius: 50%;  */
  /* 如果图标是方形，可以设置为圆形 */
  /* 其他样式，如阴影、透明度等 */
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
   /* 轻微的阴影效果 */
}

/* 关键帧动画 */
@keyframes floatAnim {
  0%, 100% {
    transform: translateY(-40rpx);
  }
  50% {
    transform: translateY(40rpx);
  }
}


.trigger-btn {
  position: fixed;
  left: 0;
  top: 75%;
  width: 28px;
  height: 96px;
  background: #27d0fe;
  padding-left: 9rpx;
  font-weight: bold;
  border-radius: 0 8px 8px 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
  transform: translateY(-50%);
  transform: translateX(-100%);
  color: #ffffff;
  gap: 6rpx;
}

.slide-panel {
  position: fixed;
  left: 0;
  top: 70%;
  width: 220rpx;
  /* background: white;
  box-shadow: 2px 0 10px rgba(0,0,0,0.1); */
  transform: translateX(0%);
}

.panel-header {
  height: 120rpx;
  background: #07C160;
  color: white;
  display: flex;
  align-items: center;
  padding-left: 30rpx;
}

.panel-body {
  padding: 20rpx;
}

.panel-item {
  display: flex;
  align-items: center;
  padding: 25rpx 15rpx;
  border-bottom: 1rpx solid #eee;
}

.panel-item image {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.deeptutor-entry-shell {
  width: 200rpx;
}

.deeptutor-entry-close {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 8rpx;
}

.close-btn-shop-entry{
  width: 56rpx;
  height: 56rpx;
}

.deeptutor-entry-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
  width: 176rpx;
  min-height: 186rpx;
  padding: 18rpx 16rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #4ec6ff 0%, #2f79ff 100%);
  box-shadow: 0 12rpx 30rpx rgba(38, 102, 255, 0.28);
}

.deeptutor-entry-badge {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  border: 2rpx solid rgba(255, 255, 255, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.deeptutor-entry-title {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 700;
}

.deeptutor-entry-subtitle {
  color: rgba(255, 255, 255, 0.96);
  font-size: 22rpx;
  line-height: 1.4;
}

.deeptutor-entry-tip {
  margin-top: 4rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 20rpx;
}








