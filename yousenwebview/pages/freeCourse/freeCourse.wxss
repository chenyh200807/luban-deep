page {
  height: 100%;
  background: #f3f5f9;
}

.yousen-page {
  height: 100vh;
  background: #f3f5f9;
  overflow: hidden;
}

.page-scroll {
  height: 100vh;
}

.page-scroll-inner {
  min-height: 100vh;
}

.brand-hero {
  position: relative;
  height: 304rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #7e8fab 0%, #aebad2 100%);
}

.brand-hero-bg {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
  transform: scale(1.08);
  opacity: 0.42;
}

.brand-hero-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background:
    linear-gradient(135deg, rgba(76, 97, 130, 0.30) 0%, rgba(210, 219, 235, 0.18) 100%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(50, 68, 99, 0.16) 100%);
}

.brand-hero-content {
  position: relative;
  z-index: 1;
  height: 100%;
  padding: 88rpx 42rpx 0;
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
}

.hero-brand-image {
  width: 360rpx;
  display: block;
}

.hero-ai-bridge {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 0 0 36rpx;
  padding: 18rpx 18rpx 18rpx 18rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(16, 35, 60, 0.06);
  box-shadow: 0 20rpx 46rpx rgba(9, 20, 35, 0.12);
}

.hero-ai-bridge-mark {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: #10233c;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.hero-ai-bridge-copy {
  flex: 1;
  min-width: 0;
}

.hero-ai-bridge-title {
  display: block;
  font-size: 28rpx;
  color: #10233c;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.hero-ai-bridge-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: rgba(16, 35, 60, 0.8);
  font-weight: 600;
}

.hero-ai-bridge-cta {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 8rpx 8rpx 22rpx;
  border-radius: 999rpx;
  background: #10233c;
  border: 1rpx solid rgba(16, 35, 60, 0.04);
  flex-shrink: 0;
}

.hero-ai-bridge-cta-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 0.6rpx;
  white-space: nowrap;
}

.hero-ai-bridge-cta-arrow {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(4, 10, 18, 0.14);
}

.hero-ai-bridge-cta-arrow-text {
  font-size: 30rpx;
  line-height: 1;
  color: #0f223b;
}

.content-sheet {
  position: relative;
  z-index: 4;
  margin-top: -30rpx;
  min-height: calc(100vh - 274rpx);
  padding: 0 32rpx 0;
  background: #ffffff;
  border-radius: 42rpx 42rpx 0 0;
  box-sizing: border-box;
  box-shadow: 0 -12rpx 32rpx rgba(12, 24, 42, 0.06);
}

.content-sheet-scroll-head {
  padding: 28rpx 0 28rpx;
}

.content-sheet-section-head {
  margin-top: 34rpx;
}

.content-sheet-service-banner {
  margin-top: 26rpx;
}

.sheet-topline {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 2rpx;
}

.sheet-copy {
  min-width: 0;
  flex: 1;
}

.sheet-label {
  display: block;
  font-size: 20rpx;
  letter-spacing: 2.6rpx;
  color: rgba(16, 35, 60, 0.38);
}

.sheet-title {
  display: block;
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 1.12;
  color: #10233c;
  font-weight: 700;
}

.direction-picker {
  display: block;
  flex-shrink: 0;
}

.direction-picker-inner {
  min-width: 196rpx;
  height: 78rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid rgba(16, 35, 60, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.direction-picker-value {
  font-size: 22rpx;
  color: #10233c;
  font-weight: 600;
}

.direction-picker-icon {
  width: 36rpx;
  height: 36rpx;
}

.rotate-image {
  transition: transform 0.25s ease;
}

.course-section {
  margin-top: 0;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 32rpx;
  color: #10233c;
  font-weight: 700;
}

.section-count {
  font-size: 22rpx;
  color: rgba(16, 35, 60, 0.42);
}

.teacher-row {
  display: flex;
  align-items: center;
  min-width: 0;
}

.teacher-avatars {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.teacher-avatar {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  background: #dfe5ec;
}

.teacher-avatar + .teacher-avatar {
  margin-left: -10rpx;
}

.teacher-copy {
  margin-left: 14rpx;
  min-width: 0;
}

.teacher-name {
  font-size: 20rpx;
  color: rgba(16, 35, 60, 0.44);
}

.course-empty {
  padding: 72rpx 12rpx 80rpx;
  text-align: center;
}

.course-empty-title {
  display: block;
  font-size: 32rpx;
  color: #10233c;
  font-weight: 700;
}

.course-empty-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(16, 35, 60, 0.5);
}

.course-card {
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid rgba(16, 35, 60, 0.08);
  box-shadow: 0 16rpx 40rpx rgba(16, 35, 60, 0.05);
}

.course-media {
  width: 100%;
  height: 320rpx;
  display: block;
  background: #e6ebf2;
}

.course-content {
  padding: 26rpx 24rpx 24rpx;
}

.course-heading {
  display: flex;
  flex-direction: column;
}

.course-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: rgba(16, 35, 60, 0.06);
  color: #10233c;
  font-size: 18rpx;
  font-weight: 600;
}

.course-title {
  display: block;
  margin-top: 14rpx;
  font-size: 32rpx;
  line-height: 1.38;
  color: #10233c;
  font-weight: 700;
}

.course-footer {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.course-action {
  min-width: 172rpx;
  height: 68rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #10233c;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.course-action-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 700;
}

.service-banner {
  position: relative;
  overflow: hidden;
  margin-top: 30rpx;
  border-radius: 28rpx;
  background: #10233c;
}

.service-banner-image {
  width: 100%;
  height: 220rpx;
  display: block;
}

.service-banner-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(90deg, rgba(16, 35, 60, 0.68), rgba(16, 35, 60, 0.18));
}

.service-banner-copy {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
}

.service-banner-label {
  display: block;
  font-size: 18rpx;
  letter-spacing: 2.2rpx;
  color: rgba(255, 255, 255, 0.64);
}

.service-banner-title {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.4;
  color: #ffffff;
  font-weight: 600;
}

.bottom-space {
  height: 96rpx;
}
