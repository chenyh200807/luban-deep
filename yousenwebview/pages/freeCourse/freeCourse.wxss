page {
  height: 100%;
  background: #ffffff;
}

.yousen-page {
  height: 100vh;
  background: #ffffff;
  overflow: hidden;
}

.page-scroll {
  height: 100vh;
}

.page-scroll-inner {
  min-height: 100vh;
}

.hero-dock-spacer {
  height: calc(100vh + 860rpx);
}

.cover-hero {
  position: fixed;
  top: 0;
  right: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  min-height: 980rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 16% 12%, rgba(255, 255, 255, 0.16) 0%, transparent 34%),
    radial-gradient(circle at 88% 18%, rgba(255, 255, 255, 0.12) 0%, transparent 26%),
    linear-gradient(135deg, #13243a 0%, #1f3a57 48%, #d7dee7 100%);
  z-index: 1;
  pointer-events: none;
}

.cover-image {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
  transform-origin: center center;
}

.cover-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background:
    linear-gradient(90deg, rgba(6, 17, 31, 0.50) 0%, rgba(6, 17, 31, 0.14) 42%, rgba(6, 17, 31, 0.06) 100%),
    linear-gradient(180deg, rgba(6, 17, 31, 0.10) 0%, rgba(6, 17, 31, 0.34) 100%);
}

.cover-glow {
  position: absolute;
  top: -120rpx;
  left: -140rpx;
  width: 520rpx;
  height: 520rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.26) 0%, transparent 72%);
  filter: blur(10rpx);
  opacity: 0.72;
}

.hero-inner {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  top: 108rpx;
  z-index: 3;
  pointer-events: none;
}

.hero-brand-fixed {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  top: 108rpx;
  z-index: 12;
  pointer-events: none;
}

.hero-brand-block {
  max-width: 460rpx;
  animation: heroLiftIn 640ms cubic-bezier(0.22, 1, 0.36, 1);
}

.hero-brand-row {
  display: flex;
  align-items: flex-end;
  gap: 18rpx;
}

.hero-logo {
  width: 86rpx;
  height: 128rpx;
  display: block;
  flex-shrink: 0;
}

.hero-brand-copy {
  display: flex;
  flex-direction: column;
  padding-bottom: 10rpx;
}

.hero-brand-name {
  font-size: 60rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-brand-slogan {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.5;
  letter-spacing: 1.4rpx;
  color: rgba(255, 255, 255, 0.78);
}

.hero-anniversary-panel {
  position: absolute;
  right: 28rpx;
  top: 186rpx;
  width: 332rpx;
  min-height: 196rpx;
  transform-origin: 100% 18%;
}

.hero-anniversary-watermark {
  position: absolute;
  right: 6rpx;
  top: -8rpx;
  font-size: 186rpx;
  line-height: 0.78;
  letter-spacing: -14rpx;
  color: rgba(255, 255, 255, 0.13);
  font-weight: 700;
}

.hero-anniversary-copy {
  position: relative;
  z-index: 1;
  padding-top: 42rpx;
  text-align: right;
}

.hero-anniversary-kicker {
  display: block;
  font-size: 14rpx;
  letter-spacing: 2.8rpx;
  color: rgba(255, 255, 255, 0.44);
}

.hero-anniversary-title {
  display: block;
  margin-top: 16rpx;
  font-size: 54rpx;
  line-height: 1.04;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.96);
  font-weight: 600;
}

.hero-anniversary-foot {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  padding-top: 12rpx;
  white-space: nowrap;
}

.hero-anniversary-date,
.hero-anniversary-meta {
  display: inline-block;
  white-space: nowrap;
  font-size: 17rpx;
  line-height: 1;
  letter-spacing: 1rpx;
  color: rgba(255, 255, 255, 0.74);
}

.hero-anniversary-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.56);
  flex-shrink: 0;
}

.hero-ai-story {
  position: absolute;
  left: 48rpx;
  right: 48rpx;
  bottom: 214rpx;
  z-index: 3;
  pointer-events: auto;
}

.hero-ai-story-copy {
  width: 100%;
  max-width: 520rpx;
}

.hero-ai-story-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.66);
  text-shadow: 0 6rpx 24rpx rgba(4, 10, 18, 0.18);
}

.hero-ai-story-title {
  display: block;
  margin-top: 16rpx;
  font-size: 50rpx;
  line-height: 1.02;
  color: #ffffff;
  font-weight: 700;
  letter-spacing: 1.2rpx;
  text-shadow: 0 12rpx 28rpx rgba(4, 10, 18, 0.24);
}

.hero-ai-story-subtitle {
  display: block;
  margin-top: 22rpx;
  max-width: 520rpx;
  font-size: 30rpx;
  line-height: 1.44;
  color: rgba(255, 255, 255, 0.96);
  font-weight: 600;
  text-shadow: 0 8rpx 22rpx rgba(4, 10, 18, 0.18);
}

.hero-ai-story-detail {
  display: block;
  margin-top: 18rpx;
  max-width: 520rpx;
  font-size: 22rpx;
  line-height: 1.72;
  color: rgba(255, 255, 255, 0.82);
  text-shadow: 0 8rpx 22rpx rgba(4, 10, 18, 0.16);
}

.hero-ai-story-action {
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 30rpx;
  padding: 10rpx 12rpx 10rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 14rpx 34rpx rgba(4, 10, 18, 0.14);
}

.hero-ai-story-action-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 0.6rpx;
}

.hero-ai-story-action-arrow {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 1;
}

.hero-ai-bridge {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 28rpx 28rpx 36rpx;
  padding: 18rpx 18rpx 18rpx 18rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(16, 35, 60, 0.06);
  box-shadow: 0 20rpx 46rpx rgba(9, 20, 35, 0.12);
}

.hero-ai-bridge-mark {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: #10233c;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.hero-ai-bridge-copy {
  flex: 1;
  min-width: 0;
}

.hero-ai-bridge-title {
  display: block;
  font-size: 28rpx;
  color: #10233c;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.hero-ai-bridge-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: rgba(16, 35, 60, 0.8);
  font-weight: 600;
}

.hero-ai-bridge-cta {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 8rpx 8rpx 22rpx;
  border-radius: 999rpx;
  background: #10233c;
  border: 1rpx solid rgba(16, 35, 60, 0.04);
  flex-shrink: 0;
}

.hero-ai-bridge-cta-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 0.6rpx;
  white-space: nowrap;
}

.hero-ai-bridge-cta-arrow {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(4, 10, 18, 0.14);
}

.hero-ai-bridge-cta-arrow-text {
  font-size: 30rpx;
  line-height: 1;
  color: #0f223b;
}

.content-sheet {
  position: relative;
  z-index: 4;
  min-height: 100vh;
}

.content-sheet.is-docked {
  position: fixed;
  left: 0;
  right: 0;
  top: 304rpx;
  bottom: 0;
  z-index: 8;
  min-height: 0;
  background: #ffffff;
  border-radius: 42rpx 42rpx 0 0;
  overflow: hidden;
}

.content-sheet-body {
  position: relative;
  z-index: 4;
  min-height: 0;
  padding: 0 32rpx 0;
  background: #ffffff;
  box-sizing: border-box;
  border-radius: 42rpx 42rpx 0 0;
  box-shadow: 0 10rpx 28rpx rgba(12, 24, 42, 0.06);
  overflow: hidden;
}

.content-sheet-body.is-docked {
  margin-top: 0;
}

.content-sheet-scroll-head {
  padding: 20rpx 0 28rpx;
}

.content-sheet-section-head {
  margin-top: 34rpx;
}

.content-sheet-service-banner {
  margin-top: 26rpx;
}

.sheet-topline {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 2rpx;
}

.sheet-copy {
  min-width: 0;
  flex: 1;
}

.sheet-label {
  display: block;
  font-size: 20rpx;
  letter-spacing: 2.6rpx;
  color: rgba(16, 35, 60, 0.38);
}

.sheet-title {
  display: block;
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 1.12;
  color: #10233c;
  font-weight: 700;
}

.direction-picker {
  display: block;
  flex-shrink: 0;
}

.direction-picker-inner {
  min-width: 196rpx;
  height: 78rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid rgba(16, 35, 60, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.direction-picker-value {
  font-size: 22rpx;
  color: #10233c;
  font-weight: 600;
}

.direction-picker-icon {
  width: 36rpx;
  height: 36rpx;
}

.rotate-image {
  transition: transform 0.25s ease;
}

.course-section {
  margin-top: 0;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 32rpx;
  color: #10233c;
  font-weight: 700;
}

.section-count {
  font-size: 22rpx;
  color: rgba(16, 35, 60, 0.42);
}

.teacher-row {
  display: flex;
  align-items: center;
  min-width: 0;
}

.teacher-avatars {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.teacher-avatar {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  background: #dfe5ec;
}

.teacher-avatar + .teacher-avatar {
  margin-left: -10rpx;
}

.teacher-copy {
  margin-left: 14rpx;
  min-width: 0;
}

.teacher-name {
  font-size: 20rpx;
  color: rgba(16, 35, 60, 0.44);
}

.course-empty {
  padding: 72rpx 12rpx 80rpx;
  text-align: center;
}

.course-empty-title {
  display: block;
  font-size: 32rpx;
  color: #10233c;
  font-weight: 700;
}

.course-empty-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(16, 35, 60, 0.5);
}

.course-card {
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid rgba(16, 35, 60, 0.08);
  box-shadow: 0 16rpx 40rpx rgba(16, 35, 60, 0.05);
}

.course-media {
  width: 100%;
  height: 320rpx;
  display: block;
  background: #e6ebf2;
}

.course-content {
  padding: 26rpx 24rpx 24rpx;
}

.course-heading {
  display: flex;
  flex-direction: column;
}

.course-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: rgba(16, 35, 60, 0.06);
  color: #10233c;
  font-size: 18rpx;
  font-weight: 600;
}

.course-title {
  display: block;
  margin-top: 14rpx;
  font-size: 32rpx;
  line-height: 1.38;
  color: #10233c;
  font-weight: 700;
}

.course-footer {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.course-action {
  min-width: 172rpx;
  height: 68rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #10233c;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.course-action-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 700;
}

.service-banner {
  position: relative;
  overflow: hidden;
  margin-top: 30rpx;
  border-radius: 28rpx;
  background: #10233c;
}

.service-banner-image {
  width: 100%;
  height: 220rpx;
  display: block;
}

.service-banner-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(90deg, rgba(16, 35, 60, 0.68), rgba(16, 35, 60, 0.18));
}

.service-banner-copy {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
}

.service-banner-label {
  display: block;
  font-size: 18rpx;
  letter-spacing: 2.2rpx;
  color: rgba(255, 255, 255, 0.64);
}

.service-banner-title {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.4;
  color: #ffffff;
  font-weight: 600;
}

.bottom-space {
  height: 96rpx;
}

@keyframes heroLiftIn {
  0% {
    opacity: 0;
    transform: translateY(24rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}
