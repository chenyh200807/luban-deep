<view class="container">
  <view class="title">PDF文件列表</view>
  
  <!-- 加载提示 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-icon">⏳</view>
    <view class="loading-text">加载中...</view>
  </view>
  
  <!-- PDF列表 -->
  <view class="pdf-list" wx:else>
    <view class="pdf-item" wx:for="{{pdfFiles}}" wx:key="id" bindtap="previewPdf" data-index="{{index}}">
      <view class="pdf-icon">
        <view class="icon">📄</view>
      </view>
      <view class="pdf-info">
        <view class="pdf-name">{{item.name}}</view>
        <view class="pdf-size">{{item.type === 'online' ? '在线文件' : '本地文件'}} · {{item.size}}</view>
      </view>
      <view class="pdf-arrow">→</view>
    </view>
    
    <!-- 本地PDF选择按钮 -->
    <view class="pdf-item add-item" bindtap="chooseLocalPdf">
      <view class="pdf-icon">
        <view class="icon">➕</view>
      </view>
      <view class="pdf-info">
        <view class="pdf-name">添加本地PDF文件</view>
        <view class="pdf-size">从手机中选择PDF文件</view>
      </view>
      <view class="pdf-arrow">→</view>
    </view>
  </view>
  
  <!-- 错误提示 -->
  <view class="tips" wx:if="{{errorMsg}}">{{errorMsg}}</view>
</view>
    