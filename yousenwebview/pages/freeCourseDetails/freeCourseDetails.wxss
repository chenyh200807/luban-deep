/* package/freeCourseDetails/freeCourseDetails.wxss */
page{
  background: #F6F7F9;
  height: 100%;
}
.video_wrap{
  width: 100%;
  height: 400rpx;
}
.freeCourse_item>image{
  width: 27rpx;
  height: 27rpx;
}

.freeCourse_bottom{
  position: fixed;
  bottom: 50rpx;
  left: 50%;
  margin-left: -350rpx;
  width: 700rpx;
  height: 88rpx;
  background: #FF5544;
  border-radius: 44rpx;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
}
.freeCourse_bottom>image{
  width: 44rpx;
  height: 44rpx;
}
.free_active{
  color: #FF5544 !important;
}

.show_active{
  color: #fd0c2d;
    padding-bottom: 10px;
    border-bottom: 1px solid #fd0c2d;
}

.container {
  display: flex;
  background-color: white;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
}

.header {
  width: 100%;
  padding: 20rpx 0;
  background-color: #f8f8f8; /* 顶部栏背景色 */
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}

.content {
  width: 100%;
  padding: 40rpx;
}

.watch-btn {
  width: 100%;
  margin-top: 40rpx;
  background-color: #1AAD19; /* 按钮颜色 */
  color: white; /* 按钮字体颜色 */
  font-size: 32rpx;
  border-radius: 40rpx; /* 圆角按钮 */
}
