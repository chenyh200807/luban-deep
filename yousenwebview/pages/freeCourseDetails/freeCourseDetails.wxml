<!--package/freeCourseDetails/freeCourseDetails.wxml-->
<view class="course-page">
  <view wx:if="{{detailError}}" class="state-panel state-panel--error">{{detailError}}</view>
  <view wx:elif="{{loadingDetail}}" class="state-panel">课程加载中...</view>

  <block wx:else>
    <view class="hero-wrap">
      <view class="hero-glow hero-glow--left"></view>
      <view class="hero-glow hero-glow--right"></view>

      <view class="hero-copy">
        <view class="hero-kicker">佑森好课</view>
        <view class="hero-title ell-2">{{hdata.title}}</view>
        <view class="hero-chip-row">
          <view class="hero-chip hero-chip--accent">直播回放</view>
          <view class="hero-chip">共{{chapterCount}}讲</view>
          <view class="hero-chip" wx:if="{{currentChapterNumber}}">第{{currentChapterNumber}}讲</view>
        </view>
      </view>

      <view class="video-shell" wx:if="{{show}}">
        <video
          id="myVideo"
          bindtap="isShowBsClick"
          autoplay="{{videoSrc.autoplay}}"
          src="{{videoSrc.src}}"
          class="video-player"
          bindplay="staPlay"
          bindpause="endPlay"
          bindloadedmetadata="handleVideoReady"
          bindcanplay="handleVideoReady"
          bindfullscreenchange="handleFullscreenChange"
          object-fit="contain"
          page-gesture="true"
          show-center-play-btn="false"
          show-fullscreen-btn="{{true}}"
        >
          <cover-view class="speed-wrap" wx:if="{{videoSrc.isShowBeishu}}">
            <cover-view wx:if="{{!videoSrc.showBeishu}}" class="speed-trigger" catchtap="clickShowBeishu">{{videoSrc.view}}</cover-view>
            <block wx:if="{{videoSrc.showBeishu}}">
              <cover-view class="speed-option" data-bei="0.8" data-view="0.8x" catchtap="itemClick">0.8x</cover-view>
              <cover-view class="speed-option" data-bei="1.0" data-view="1.0x" catchtap="itemClick">1.0x</cover-view>
              <cover-view class="speed-option" data-bei="1.25" data-view="1.25x" catchtap="itemClick">1.25x</cover-view>
              <cover-view class="speed-option" data-bei="1.5" data-view="1.5x" catchtap="itemClick">1.5x</cover-view>
              <cover-view class="speed-option" data-bei="2.0" data-view="2.0x" catchtap="itemClick">2.0x</cover-view>
            </block>
          </cover-view>
        </video>
      </view>

      <view wx:else class="video-shell video-shell--placeholder">
        <view class="video-placeholder-title">课程暂未开放播放</view>
        <view class="video-placeholder-subtitle">你仍然可以先查看课时目录与课程说明</view>
      </view>
    </view>

    <view class="course-summary">
      <view class="summary-main">
        <view class="summary-title ell-2">{{hdata.title}}</view>
      </view>

      <view class="summary-progress">
        <view class="summary-progress-head">
          <text class="summary-progress-label">学习进度</text>
          <text class="summary-progress-value">第{{currentChapterNumber}}讲 / 共{{chapterCount}}讲</text>
        </view>
        <view class="summary-progress-track">
          <view class="summary-progress-fill" style="width: {{progressPercent}}%;"></view>
        </view>
      </view>

      <view class="summary-metrics">
        <view class="metric-item">
          <view class="metric-value">{{chapterCount}}</view>
          <view class="metric-label">课时总数</view>
        </view>
        <view class="metric-item">
          <view class="metric-value">{{currentChapterNumber}}</view>
          <view class="metric-label">当前讲次</view>
        </view>
        <view class="metric-item">
          <view class="metric-value">直播</view>
          <view class="metric-label">学习形式</view>
        </view>
      </view>

      <view class="summary-tag-row">
        <view class="summary-tag">考点梳理</view>
        <view class="summary-tag">章节回看</view>
        <view class="summary-tag">资料说明</view>
      </view>
    </view>

    <view class="detail-tabs">
      <view class="detail-tab {{showmulu ? 'detail-tab--active' : ''}}" catchtap="showmulu">
        <view class="detail-tab-title">课时</view>
        <view class="detail-tab-meta">{{chapterCount}}节</view>
      </view>
      <view class="detail-tab {{neirong1 ? 'detail-tab--active' : ''}}" catchtap="showneirong">
        <view class="detail-tab-title">课程说明</view>
        <view class="detail-tab-meta">详情</view>
      </view>
    </view>

    <view wx:if="{{showmulu}}" id="course-catalog" class="section-block">
      <view class="section-head">
        <view class="section-title">课程轨道</view>
        <view class="section-caption">按讲次顺序浏览，当前播放课时会高亮显示</view>
      </view>

      <view class="chapter-list">
        <block wx:for="{{gratisDetail.chapter}}" wx:key="id">
          <view
            id="{{currentChapterNumber == item.displayIndex ? 'current-chapter' : ''}}"
            class="chapter-item {{activeChapterIndex == index ? 'chapter-item--active' : ''}}"
            data-video_id="{{item.play_id}}"
            data-index="{{index}}"
            data-flag="{{activeChapterIndex != index}}"
            catchtap="choicePlays"
          >
            <view class="chapter-index {{currentChapterNumber == item.displayIndex ? 'chapter-index--current' : ''}}">
              {{item.displayIndex}}
            </view>

            <view class="chapter-main">
              <view class="chapter-title {{activeChapterIndex == index ? 'chapter-title--active' : ''}} ell">{{item.title}}</view>
              <view class="chapter-meta-row">
                <view wx:if="{{activeChapterIndex == index}}" class="chapter-tag chapter-tag--accent">正在学习</view>
                <view wx:elif="{{currentChapterNumber == item.displayIndex}}" class="chapter-tag chapter-tag--recent">最近学习</view>
                <view wx:else class="chapter-tag">点击进入</view>
                <view class="chapter-tag">支持回看</view>
              </view>
            </view>

            <view class="chapter-action">
              <image src="{{activeChapterIndex == index ? '/images/icon/live_icon.png' : '/images/icon/play_icon_01.png'}}"></image>
              <view class="chapter-action-text">{{activeChapterIndex == index ? '播放中' : '进入'}}</view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view wx:if="{{neirong1}}" class="section-block intro-block">
      <view class="section-head">
        <view class="section-title">课程说明</view>
        <view class="section-caption">查看课程介绍、配套说明与学习建议</view>
      </view>
      <view class="intro-rich">
        <rich-text nodes="{{neirong}}"></rich-text>
      </view>
    </view>
  </block>

  <view wx:if="{{!detailError && !loadingDetail}}" class="bottom-actions">
    <view class="bottom-action bottom-action--secondary" catchtap="openCatalog">课时目录</view>
    <view class="bottom-action bottom-action--primary">
      <image src="/images/icon/share_icon_02.png"></image>
      <text>分享课程</text>
      <button open-type="share" class="share-overlay"></button>
    </view>
  </view>
</view>
<PhoneBox id="phone"></PhoneBox>
