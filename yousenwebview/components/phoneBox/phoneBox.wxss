/* components/phoneBox/phoneBox.wxss */
.clb-popup-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.clb-popup-panel {
  width: 100%;
  display: flex;
  justify-content: center;
}

.clb-popup-content {
  width: 626rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx !important;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 47rpx;
  box-sizing: border-box;
}
.clb-popup-title {
  padding-top: 40rpx;
  font-size: 28rpx;
}
.clb-popup-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  overflow: hidden;
  margin: 40rpx 0;
}
.clb-popup-desc {
  font-size: 24rpx;
  color: #666666;
  font-weight: 400;
}
.clb-phone-btn {
  background-color: #FEC200;
  color: #FFFFFF;
  width: 100%;
  height: 82rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  border-radius: 41rpx;
  margin: 50rpx 0 30rpx;
}
