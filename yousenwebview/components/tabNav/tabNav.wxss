/* components/tabNav/tabNav.wxss */
.tabNavwrap{
  width: 100%;
  height: 80rpx;
  background: #fff;
}
.tabNavwrap>scroll-view{
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  white-space: nowrap;
  height: 100%;
  line-height: 80rpx;
}
.tab-item{
  display: inline-block;
  color: #666;
  font-size: 24rpx;
  line-height: 80rpx;
}
.nav_active{
  position: relative;
  color: #FF5544;
  font-weight: bold;
}
.nav_active::after{
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 80%;
  height: 4rpx;
  margin-left: -40%;
  background: #FEC200;
}