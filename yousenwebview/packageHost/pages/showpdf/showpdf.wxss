.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin: 30rpx 0;
  padding-left: 10rpx;
}

.pdf-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.pdf-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 5rpx rgba(0,0,0,0.1);
  transition: transform 0.2s;
}

.pdf-item:active {
  transform: scale(0.99);
}

.add-item {
  border: 2rpx dashed #ccc;
}

.pdf-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.icon {
  font-size: 60rpx;
}

.pdf-info {
  flex: 1;
  overflow: hidden;
}

.pdf-name {
  font-size: 32rpx;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 5rpx;
}

.pdf-size {
  font-size: 24rpx;
  color: #999;
}

.pdf-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 10rpx;
}

.tips {
  color: #ff4d4f;
  font-size: 28rpx;
  text-align: center;
  margin-top: 30rpx;
  padding: 0 20rpx;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}
