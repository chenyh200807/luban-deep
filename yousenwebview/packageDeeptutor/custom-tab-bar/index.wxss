.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #09111f;
  border-top: 1rpx solid rgba(148, 163, 184, 0.10);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding-top: 10rpx;
}

.tab-icon {
  width: 42rpx;
  height: 42rpx;
  opacity: 0.82;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.tab-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #b7c0d2;
}

.tab-item.active .tab-icon {
  opacity: 1;
}
.tab-item.active .tab-text {
  color: #60a5fa;
  font-weight: 700;
}

