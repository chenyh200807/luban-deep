/* ── 亮色模式 ──────────────────────────────── */
.tab-bar.light {
  background: rgba(248, 250, 255, 0.98);
  border-top-color: #dbe6f5;
}
.tab-bar.light .tab-text {
  color: #5a6475;
}
.tab-bar.light .tab-item.active .tab-text {
  color: #2f6bff;
}
