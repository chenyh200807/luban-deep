<view class="scene {{isDark?'':'light'}}">
  <view class="sky-wash"></view>
  <view class="page-shell">
    <scroll-view class="body" scroll-y enhanced="{{true}}" bounces="{{true}}" show-scrollbar="{{false}}" style="padding-top:{{statusBarHeight}}px">
      <view class="spacer"></view>

      <view class="title-row">
        <image class="title-logo" src="../../images/logo-mark-white.png" mode="heightFix" />
        <text class="h-white title-main">鲁班智考</text>
      </view>
      <view class="headline">
        <text class="h-white">创建你的</text>
        <text class="h-blue">备考账号</text>
      </view>

      <view class="subtitle-wrap">
        <text class="subtitle">填写账号、手机号和登录密码，注册后即可开始练习，也可用于后续密码登录与账号找回。</text>
      </view>

      <view class="form">
        <view class="inp-group">
          <view class="inp-icon">
            <text class="inp-icon-tag">ID</text>
          </view>
          <input class="inp" value="{{username}}" bindinput="onUsernameInput"
            placeholder="设置用户名或邮箱" placeholder-class="ph" maxlength="50" />
        </view>

        <view class="inp-group">
          <view class="inp-icon">
            <text class="inp-icon-tag">+86</text>
          </view>
          <input class="inp inp-phone" type="number" value="{{phone}}" bindinput="onPhoneInput"
            placeholder="请输入手机号" placeholder-class="ph" maxlength="11" />
        </view>

        <view class="inp-group">
          <view class="inp-icon">
            <text class="inp-icon-tag">KEY</text>
          </view>
          <input class="inp" value="{{password}}" bindinput="onPasswordInput"
            placeholder="设置登录密码" placeholder-class="ph" password="{{!showPassword}}" maxlength="128" />
          <view class="eye" bindtap="togglePassword">
            <text class="eye-txt">{{showPassword ? '隐藏' : '显示'}}</text>
          </view>
        </view>

        <view class="inp-group">
          <view class="inp-icon">
            <text class="inp-icon-tag">OK</text>
          </view>
          <input class="inp" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput"
            placeholder="再次输入密码" placeholder-class="ph" password="{{!showConfirmPassword}}" maxlength="128" />
          <view class="eye" bindtap="toggleConfirmPassword">
            <text class="eye-txt">{{showConfirmPassword ? '隐藏' : '显示'}}</text>
          </view>
        </view>

        <view class="form-tip">
          <text class="form-tip-txt">密码至少 6 位，需同时包含大写字母、小写字母和数字。</text>
        </view>
      </view>

      <view class="action-panel" style="padding-bottom: {{safeBottom + 24}}px">
        <view class="err" wx:if="{{errorMsg}}">
          <text class="err-txt">{{errorMsg}}</text>
        </view>

        <button class="btn-main btn-main-full {{loading?'off':''}}" bindtap="handleRegister" disabled="{{loading}}">
          <text class="btn-txt">{{loading ? '创建中...' : '创建账号并开始'}}</text>
        </button>

        <view class="foot">
          <text class="foot-muted">已有账号？</text>
          <text class="foot-link" bindtap="goLogin">去登录</text>
        </view>
      </view>

      <view class="scroll-safe-space"></view>
    </scroll-view>
  </view>
</view>
