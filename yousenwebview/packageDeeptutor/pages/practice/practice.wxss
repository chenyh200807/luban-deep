@import "/packageDeeptutor/theme.wxss";

/* pages/practice/practice.wxss — 练习中心样式 */

.practice-page {
  height: 100vh;
  background: var(--bg-primary);
  overflow: hidden;
}

/* ── 导航栏 ──────────────────────────────────────── */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  background: rgba(10,10,10,0.9);
  border-bottom: 1rpx solid var(--border);
}

.nav-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  gap: 16rpx;
}

.nav-logo { height: 100rpx; margin-left: 28rpx; }

.nav-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* ── 滚动区域 ────────────────────────────────────── */
.page-scroll {
  position: fixed;
  left: 0;
  right: 0;
  overflow-y: auto;
}

.page-inner {
  padding: 24rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ── 今日目标卡片 ──────────────────────────────── */
.today-card {
  padding: 32rpx;
}

.today-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.today-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.streak-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(245,158,11,0.15);
  border: 1rpx solid rgba(245,158,11,0.3);
  border-radius: 32rpx;
  padding: 8rpx 20rpx;
}

.streak-fire { font-size: 26rpx; }
.streak-val { font-size: 24rpx; color: #f59e0b; font-weight: 600; }

.progress-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.progress-bar-bg {
  flex: 1;
  height: 16rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #3b82f6, #2563eb);
  border-radius: 8rpx;
  transition: width 0.5s ease;
  min-width: 4rpx;
}

.progress-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

/* ── Section Header ────────────────────────────── */
.section-header {
  padding: 8rpx 4rpx 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* ── 练习模式 2×2 ─────────────────────────────── */
.mode-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.mode-card {
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  border-top: 3rpx solid var(--accent, #3b82f6);
  cursor: pointer;
  transition: all 0.15s;
}

.mode-card:active {
  transform: scale(0.97);
}

.mode-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mode-icon { font-size: 36rpx; }

.mode-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.mode-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ── 报告入口 ──────────────────────────────────── */
.report-card {
  padding: 28rpx 32rpx;
}

.report-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.report-icon { font-size: 40rpx; }

.report-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.report-sub {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

/* ── 骨架屏 ───────────────────────────────────── */
.skel-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
}

.skel-title {
  height: 28rpx;
  width: 60%;
  border-radius: 8rpx;
}

.skel-bar {
  height: 16rpx;
  width: 100%;
  border-radius: 8rpx;
}

/* ── 章节列表 ─────────────────────────────────── */
.chapters-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.chapter-item {
  padding: 24rpx 28rpx;
}

.chapter-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.chapter-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.chapter-stat {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.chapter-bar-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chapter-bar-bg {
  flex: 1;
  height: 12rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 6rpx;
  overflow: hidden;
}

.chapter-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  background: var(--primary-500);
  transition: width 0.5s ease;
}

.chapter-pct {
  font-size: 22rpx;
  color: var(--text-secondary);
  min-width: 52rpx;
  text-align: right;
}

/* ══ Light Mode ══════════════════════════════ */
.practice-page.light {
  background: #f8fafc;
}

/* ── 导航栏 ──────────────────────────────── */
.practice-page.light .nav-bar {
  background: rgba(248,250,252,0.92);
  border-bottom-color: rgba(0,0,0,0.06);
}
.practice-page.light .nav-logo { filter: brightness(0); }
.practice-page.light .nav-title { color: #0f172a; }

/* ── 今日目标卡片 ────────────────────────── */
.practice-page.light .glass-card {
  background: #ffffff;
  border-color: #e5e5e5;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.practice-page.light .today-label { color: #0f172a; }
.practice-page.light .streak-badge {
  background: #fff8e6;
  border-color: #f7cf8c;
}

/* ── 进度条 ──────────────────────────────── */
.practice-page.light .progress-bar-bg {
  background: rgba(0,0,0,0.06);
}
.practice-page.light .progress-label { color: #666; }

/* ── Section Header ──────────────────────── */
.practice-page.light .section-title { color: #0f172a; }

/* ── 练习模式卡片 ────────────────────────── */
.practice-page.light .mode-title { color: #0f172a; }
.practice-page.light .mode-desc { color: #666; }

/* ── 报告入口 ────────────────────────────── */
.practice-page.light .report-card {
  display: flex; justify-content: space-between; align-items: center;
}
.practice-page.light .report-title { color: #0f172a; }
.practice-page.light .report-sub { color: #666; }
.practice-page.light .link-arrow { color: #999; }

/* ── 骨架屏 ──────────────────────────────── */
.practice-page.light .skel-row {
  background: #f5f5f5;
}
.practice-page.light .skel-block {
  background: rgba(0,0,0,0.06);
}

/* ── 章节列表 ────────────────────────────── */
.practice-page.light .chapter-name { color: #0f172a; }
.practice-page.light .chapter-stat { color: #666; }
.practice-page.light .chapter-bar-bg {
  background: rgba(0,0,0,0.06);
}
.practice-page.light .chapter-pct { color: #666; }
