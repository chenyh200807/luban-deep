<view class="manual-page {{isDark?'':'light'}}">
  <view class="sky-wash"></view>

  <view class="page-shell">
    <scroll-view class="body" scroll-y enhanced="{{true}}" bounces="{{true}}" show-scrollbar="{{false}}" style="padding-top:{{statusBarHeight}}px">
      <view class="nav-row">
        <view class="nav-back" bindtap="goBack">
          <text class="nav-back-arrow">‹</text>
          <text class="nav-back-txt">返回</text>
        </view>
      </view>

      <view class="hero">
        <view class="title-row">
          <image class="title-logo" src="../../images/logo-mark-white.png" mode="heightFix" />
          <text class="title-main">Luban AI Tutor</text>
        </view>
        <text class="hero-title">其他登录方式</text>
        <text class="hero-sub">手机号验证码或账号密码登录，用于备用登录与账号找回。</text>
      </view>

      <view class="sheet">
        <view class="mode-switch">
          <view
            class="mode-pill {{loginMode === 'phone_code' ? 'mode-pill-active' : ''}}"
            data-mode="phone_code"
            bindtap="switchLoginMode"
          >
            <text class="mode-pill-txt">手机号验证码</text>
          </view>
          <view
            class="mode-pill {{loginMode === 'password' ? 'mode-pill-active' : ''}}"
            data-mode="password"
            bindtap="switchLoginMode"
          >
            <text class="mode-pill-txt">账号密码</text>
          </view>
        </view>

        <view class="err" wx:if="{{errorMsg}}">
          <text class="err-txt">{{errorMsg}}</text>
        </view>

        <view class="manual-form" wx:if="{{loginMode === 'phone_code'}}">
          <view class="inp-group">
            <view class="inp-icon">
              <text class="inp-icon-txt">+86</text>
            </view>
            <input class="inp inp-phone" type="number" value="{{username}}" bindinput="onUsernameInput"
              placeholder="请输入手机号" placeholder-class="ph" maxlength="11" />
          </view>
          <view class="code-row">
            <view class="inp-group code-input">
              <view class="inp-icon">
                <text class="inp-icon-shield">🔐</text>
              </view>
              <input class="inp inp-code" type="number" value="{{phoneCode}}" bindinput="onPhoneCodeInput"
                placeholder="输入验证码" placeholder-class="ph" maxlength="6" />
            </view>
            <view class="btn-send {{codeCountdown > 0 ? 'btn-send-counting' : ''}} {{loading ? 'btn-send-off' : ''}}"
              bindtap="sendCode">
              <text class="btn-send-txt">{{codeCountdown > 0 ? codeCountdown + 's 后重发' : '获取验证码'}}</text>
            </view>
          </view>
          <button class="btn-manual {{loading?'off':''}}" bindtap="verifyCode" disabled="{{loading}}">
            <text class="btn-manual-txt">{{loading ? '登录中...' : '继续使用手机号登录'}}</text>
          </button>
        </view>

        <view class="manual-form" wx:if="{{loginMode === 'password'}}">
          <view class="inp-group">
            <view class="inp-icon"><text class="inp-icon-txt">ID</text></view>
            <input class="inp" value="{{username}}" bindinput="onUsernameInput"
              placeholder="用户名" placeholder-class="ph" maxlength="50" />
          </view>
          <view class="inp-group">
            <view class="inp-icon"><text class="inp-icon-shield">🔑</text></view>
            <input class="inp" style="flex:1;" value="{{password}}" bindinput="onPasswordInput"
              placeholder="密码" placeholder-class="ph" password="{{!showPassword}}" maxlength="128" />
            <view class="eye" bindtap="togglePassword">
              <text class="eye-txt">{{showPassword ? '隐藏' : '显示'}}</text>
            </view>
          </view>
          <button class="btn-manual {{loading?'off':''}}" bindtap="handlePasswordLogin" disabled="{{loading}}">
            <text class="btn-manual-txt">{{loading ? '登录中...' : '继续使用账号登录'}}</text>
          </button>
        </view>

        <view class="foot">
          <text class="foot-link" bindtap="goRegister">去注册</text>
        </view>

      </view>

      <view style="height: {{safeBottom + 32}}px"></view>
    </scroll-view>
  </view>
</view>
