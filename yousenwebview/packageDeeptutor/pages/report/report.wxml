<!-- pages/report/report.wxml — 学情页：诊断 + AI作战方案 + 进步反馈 -->
<view class="report-page {{isDark?'':'light'}}">

  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px">
    <view class="nav-content">
      <view class="nav-back" bindtap="goHome">
        <text class="nav-back-arrow">‹</text>
        <text class="nav-back-txt">{{navBackLabel}}</text>
      </view>
      <text class="nav-title">学情</text>
      <view class="nav-points-pill" bindtap="goBilling">
        <text class="nav-points-star">✦</text>
        <text class="nav-points-num">{{userPoints}}</text>
      </view>
    </view>
  </view>

  <scroll-view class="page-scroll" scroll-y enhanced="{{true}}" bounces="{{true}}" show-scrollbar="{{false}}" style="top: {{navHeight}}px; bottom: 0">
    <view class="page-inner">
      <view class="section-header section-header-large">
        <view class="section-heading-copy">
          <text class="section-kicker">学情诊断</text>
          <text class="section-title">现状、薄弱项、掌握度</text>
          <text class="section-subtitle">先看当前状态，再决定今天怎么学</text>
        </view>
      </view>

      <view class="overview-hero glass-card">
        <view class="overview-head">
          <view>
            <text class="overview-title">{{learnerStageTitle}}</text>
            <text class="overview-sub">系统会根据练习表现持续更新你的学情判断</text>
          </view>
          <view class="overview-score-wrap">
            <text class="overview-score">{{diagnosticScore}}</text>
            <text class="overview-score-unit">%</text>
          </view>
        </view>
        <text class="overview-tip" wx:if="{{studyTip}}">{{studyTip}}</text>
        <view class="overview-metrics">
          <view class="metric-chip">
            <text class="metric-num">{{overallMastery || diagnosticScore}}%</text>
            <text class="metric-label">总体掌握</text>
          </view>
          <view class="metric-chip">
            <text class="metric-num">{{todayDone}} / {{dailyTarget || 0}}</text>
            <text class="metric-label">今日进度</text>
          </view>
          <view class="metric-chip metric-chip-accent">
            <text class="metric-num">{{strongCount}} / {{weakCount}}</text>
            <text class="metric-label">强项 / 薄弱</text>
          </view>
          <view class="metric-chip metric-chip-warn">
            <text class="metric-num">{{dueTodayCount}}</text>
            <text class="metric-label">今日待复习</text>
          </view>
        </view>
      </view>

      <!-- 加载中 -->
      <view wx:if="{{radarLoading}}" class="glass-card loading-card">
        <view class="skel-block" style="width: 280rpx; height: 280rpx; border-radius: 50%; margin: 0 auto"></view>
        <view class="skel-block" style="width: 60%; height: 32rpx; margin: 24rpx auto 0"></view>
      </view>

      <!-- 错误 -->
      <view wx:elif="{{radarError}}" class="glass-card empty-card">
        <text class="empty-icon">{{warnIcon}}</text>
        <text class="empty-title">加载失败</text>
        <text class="empty-desc">无法获取能力数据，请检查网络后重试</text>
        <view class="empty-btn" bindtap="retryRadar">
          <text class="empty-btn-txt">重试</text>
        </view>
      </view>

      <!-- 空数据 -->
      <view wx:elif="{{radarDimensions.length === 0 && !radarLoading}}" class="glass-card empty-card">
        <text class="empty-icon">{{radarIcon}}</text>
        <text class="empty-title">能力数据生成中</text>
        <text class="empty-desc">完成一定量的练习后，系统会自动分析你的各维度能力</text>
        <view class="empty-btn" bindtap="goPractice">
          <text class="empty-btn-txt">去练习</text>
        </view>
      </view>

      <!-- 雷达图 + 统计 -->
      <view wx:else>
        <view class="section-header sub-header">
          <text class="section-title-sm">诊断维度</text>
          <text class="section-subtitle-sm">这里看整体能力结构，具体章节放到下面的掌握分布里展开</text>
        </view>

        <!-- Canvas 雷达图（绘制后转为图片跟随滚动） -->
        <view class="radar-canvas-wrap">
          <canvas type="2d" id="radarCanvas" class="radar-canvas"
            style="{{radarImage ? 'position:fixed;left:-9999px;top:-9999px' : ''}}"></canvas>
          <image wx:if="{{radarImage}}" class="radar-image" src="{{radarImage}}" mode="aspectFit"></image>
        </view>

        <!-- 强项/一般/薄弱 统计 -->
        <view class="radar-summary">
          <view class="radar-stat">
            <view class="stat-dot dot-strong"></view>
            <text class="stat-num">{{strongCount}}</text>
            <text class="stat-label">强项</text>
          </view>
          <view class="radar-stat">
            <view class="stat-dot dot-normal"></view>
            <text class="stat-num">{{normalCount}}</text>
            <text class="stat-label">一般</text>
          </view>
          <view class="radar-stat">
            <view class="stat-dot dot-weak"></view>
            <text class="stat-num">{{weakCount}}</text>
            <text class="stat-label">薄弱</text>
          </view>
        </view>

        <view class="section-header sub-header">
          <text class="section-title-sm">各维度详情</text>
        </view>

        <view class="dim-list">
          <view
            class="dim-item glass-card"
            wx:for="{{dimList}}"
            wx:key="rank"
          >
            <view class="dim-rank rank-{{item.cls}}">
              <text class="dim-rank-txt">{{item.rank}}</text>
            </view>
            <text class="dim-name">{{item.name}}</text>
            <view class="dim-bar">
              <view
                class="dim-bar-fill"
                style="width: {{item.pct}}%; background: {{item.color}}"
              ></view>
            </view>
            <text class="dim-pct" style="color: {{item.color}}">{{item.pct}}%</text>
          </view>
        </view>
      </view>

      <view class="section-header">
        <text class="section-title">掌握分布</text>
        <text class="section-subtitle">按章节展开看掌握情况</text>
      </view>

      <!-- 加载中 -->
      <view wx:if="{{masteryLoading}}" class="glass-card loading-card">
        <view class="skel-block" style="width: 50%; height: 64rpx; margin: 0 auto"></view>
        <view class="skel-block" style="width: 80%; height: 24rpx; margin: 16rpx auto 0"></view>
      </view>

      <!-- 错误 -->
      <view wx:elif="{{masteryError}}" class="glass-card empty-card">
        <text class="empty-title">加载失败</text>
        <view class="empty-btn" bindtap="retryMastery">
          <text class="empty-btn-txt">重试</text>
        </view>
      </view>

      <!-- 掌握度数据 -->
      <view wx:else>
        <view class="mastery-hero glass-card">
          <view class="mastery-score-wrap">
            <text class="mastery-score {{overallMastery >= 70 ? 'score-good' : overallMastery >= 40 ? 'score-mid' : 'score-low'}}">
              {{overallMastery}}
            </text>
            <text class="mastery-unit">%</text>
          </view>
          <text class="mastery-label">总体掌握度</text>
          <view class="mastery-sub-row">
            <view class="mastery-sub-item">
              <text class="mastery-sub-num">{{reviewSummary.total_due || 0}}</text>
              <text class="mastery-sub-label">待复习</text>
            </view>
            <view class="mastery-sub-divider"></view>
            <view class="mastery-sub-item">
              <text class="mastery-sub-num mastery-sub-warn">{{reviewSummary.overdue_count || 0}}</text>
              <text class="mastery-sub-label">已逾期</text>
            </view>
            <view class="mastery-sub-divider"></view>
            <view class="mastery-sub-item">
              <text class="mastery-sub-num">{{hotspots.length}}</text>
              <text class="mastery-sub-label">热点</text>
            </view>
          </view>
        </view>

        <view
          class="mastery-group glass-card"
          wx:for="{{masteryGroups}}"
          wx:key="name"
        >
          <view class="group-header">
            <text class="group-name">{{item.name}}</text>
            <text class="group-avg {{item.avgMastery >= 70 ? 'avg-good' : item.avgMastery >= 40 ? 'avg-mid' : 'avg-low'}}">
              {{item.avgMastery}}%
            </text>
          </view>
          <view class="group-chapters">
            <view
              class="chapter-row"
              wx:for="{{item.chapters}}"
              wx:for-item="ch"
              wx:key="name"
            >
              <text class="ch-name">{{ch.name}}</text>
              <view class="ch-bar">
                <view
                  class="ch-bar-fill"
                  style="width: {{ch.mastery}}%; background: {{ch.color}}"
                ></view>
              </view>
              <text class="ch-pct" style="color: {{ch.color}}">{{ch.mastery}}%</text>
            </view>
          </view>
        </view>
      </view>

      <view class="section-header">
        <text class="section-title">AI作战方案</text>
        <text class="section-subtitle">下一步学什么、先做什么、今天怎么学</text>
      </view>

      <view class="battle-plan glass-card">
        <view class="battle-plan-head">
          <view>
            <text class="battle-plan-kicker">今日主攻</text>
            <text class="battle-plan-topic">{{battlePlan.focusTopic}}</text>
          </view>
          <view class="battle-plan-badge">
            <text class="battle-plan-badge-text">AI建议</text>
          </view>
        </view>
        <text class="battle-plan-note">{{battlePlan.coachNote}}</text>
        <view class="battle-plan-list">
          <view class="battle-plan-row battle-plan-row-first">
            <text class="battle-plan-label">优先任务</text>
            <text class="battle-plan-value">{{battlePlan.priorityTask}}</text>
          </view>
          <view class="battle-plan-row">
            <text class="battle-plan-label">学习顺序</text>
            <text class="battle-plan-value">{{battlePlan.studyMethod}}</text>
          </view>
          <view class="battle-plan-row">
            <text class="battle-plan-label">建议投入</text>
            <text class="battle-plan-value">{{battlePlan.timeBudget}}</text>
          </view>
        </view>
      </view>

      <view class="section-header">
        <text class="section-title">进步反馈</text>
        <text class="section-subtitle">把正在发生的变化明确展示出来</text>
      </view>

      <view class="progress-panel glass-card">
        <text class="progress-summary">{{progressSummary}}</text>
        <text class="progress-insight" wx:if="{{progressInsight}}">{{progressInsight}}</text>
        <view class="progress-grid">
          <view
            class="progress-item"
            wx:for="{{progressCards}}"
            wx:key="label"
          >
            <text class="progress-item-label">{{item.label}}</text>
            <text class="progress-item-value {{item.toneClass}}">{{item.value}}</text>
            <text class="progress-item-detail">{{item.detail}}</text>
          </view>
        </view>
        <view class="progress-milestones" wx:if="{{progressMilestones.length}}">
          <view
            class="progress-milestone"
            wx:for="{{progressMilestones}}"
            wx:key="title"
          >
            <view class="progress-milestone-dot {{item.toneClass}}"></view>
            <view class="progress-milestone-copy">
              <text class="progress-milestone-title">{{item.title}}</text>
              <text class="progress-milestone-detail">{{item.detail}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 摸底测试入口 -->
      <view class="assess-entry glass-card" wx:if="{{assessmentEnabled}}" bindtap="goAssessment">
        <view class="assess-entry-left">
          <view class="assess-entry-icon">
            <text class="assess-entry-icon-txt">AI</text>
          </view>
          <view class="assess-entry-info">
            <text class="assess-entry-title">摸底测试</text>
            <text class="assess-entry-sub">重新评估知识掌握程度</text>
          </view>
        </view>
        <text class="assess-entry-arrow">›</text>
      </view>

      <!-- 底部安全距离 -->
      <view style="height: 240rpx"></view>
    </view>
  </scroll-view>

  <workspace-shell id="workspaceShell"></workspace-shell>

</view>
