@import "/packageDeeptutor/theme.wxss";

/* pages/report/report.wxss — 学情页样式 */

.report-page {
  height: 100vh;
  background: var(--bg-primary);
  overflow: hidden;
}

/* ── 导航栏 ──────────────────────────────────────── */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  background: rgba(10, 10, 10, 0.9);
  border-bottom: 1rpx solid var(--border);
}

.nav-content {
  height: 96rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx 0 0;
  gap: 16rpx;
}

/* 返回按钮 */
.nav-back {
  display: flex; align-items: center; gap: 4rpx;
  margin-left: 20rpx; padding: 8rpx 12rpx 8rpx 4rpx;
  border-radius: 8rpx;
}
.nav-back:active { background: rgba(255,255,255,0.08); }
.nav-back-arrow {
  font-size: 40rpx; color: #818cf8; font-weight: 300;
  line-height: 1; margin-top: -4rpx;
}
.nav-back-txt { font-size: 28rpx; color: #818cf8; font-weight: 500; }

.nav-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.nav-badge {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, 0.08);
}

.nav-badge.badge-good {
  background: rgba(52, 211, 153, 0.15);
}

.nav-badge-txt {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.badge-good .nav-badge-txt {
  color: #34d399;
}

/* ── 页面滚动区 ──────────────────────────────────── */
.page-scroll {
  position: fixed;
  left: 0;
  right: 0;
  overflow-y: auto;
}

.page-inner {
  padding: 28rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.overview-hero {
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  background:
    radial-gradient(circle at top right, rgba(56, 189, 248, 0.16), transparent 34%),
    linear-gradient(145deg, rgba(99, 102, 241, 0.18), rgba(15, 23, 42, 0.12));
}

.overview-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.overview-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.overview-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  color: var(--text-muted);
}

.overview-score-wrap {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.overview-score {
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1;
  color: #7dd3fc;
}

.overview-score-unit {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(125, 211, 252, 0.8);
}

.overview-tip {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.overview-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.metric-chip {
  width: calc(50% - 6rpx);
  box-sizing: border-box;
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.metric-chip-warn {
  background: rgba(248, 113, 113, 0.08);
  border-color: rgba(248, 113, 113, 0.12);
}

.metric-chip-progress {
  border-color: rgba(56, 189, 248, 0.18);
}

.metric-chip-hover {
  opacity: 0.82;
}

.metric-chip-accent {
  background: rgba(96, 165, 250, 0.08);
  border-color: rgba(96, 165, 250, 0.14);
}

.metric-num {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.metric-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* ── Section Headers ─────────────────────────────── */
.section-header {
  padding: 6rpx 4rpx 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-header-large {
  padding-top: 4rpx;
}

.section-heading-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-kicker {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: #60a5fa;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-subtitle {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.sub-header {
  margin-top: 24rpx;
  margin-bottom: 8rpx;
}

.section-title-sm {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.section-subtitle-sm {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* ── 空状态 / 加载 ───────────────────────────────── */
.loading-card {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-card {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.empty-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  text-align: center;
  line-height: 1.5;
}

.empty-btn {
  margin-top: 16rpx;
  padding: 14rpx 40rpx;
  background: rgba(99, 102, 241, 0.15);
  border: 1rpx solid rgba(99, 102, 241, 0.3);
  border-radius: var(--radius-full);
}

.empty-btn:active {
  opacity: 0.7;
}

.empty-btn-txt {
  font-size: 26rpx;
  font-weight: 600;
  color: #818cf8;
}

/* ── 雷达图 Canvas ───────────────────────────────── */
.radar-canvas-wrap {
  display: flex;
  justify-content: center;
  padding: 32rpx 0 16rpx;
}

.radar-canvas {
  width: 560rpx;
  height: 560rpx;
  max-width: 100%;
}

.radar-image {
  width: 560rpx;
  height: 560rpx;
  max-width: 100%;
}

/* ── 雷达统计 ────────────────────────────────────── */
.radar-summary {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 16rpx;
}

.radar-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-bottom: 4rpx;
}

.dot-strong { background: #34d399; }
.dot-normal { background: #fbbf24; }
.dot-weak   { background: #f87171; }

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* ── 维度列表 ────────────────────────────────────── */
.dim-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dim-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
}

.dim-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rank-strong { background: rgba(52, 211, 153, 0.15); }
.rank-normal { background: rgba(251, 191, 36, 0.15); }
.rank-weak   { background: rgba(248, 113, 113, 0.15); }

.dim-rank-txt {
  font-size: 24rpx;
  font-weight: 700;
}

.rank-strong .dim-rank-txt { color: #34d399; }
.rank-normal .dim-rank-txt { color: #fbbf24; }
.rank-weak   .dim-rank-txt { color: #f87171; }

.dim-name {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
}

.dim-bar {
  width: 120rpx;
  height: 10rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 5rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.dim-bar-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width 0.6s ease;
}

.dim-pct {
  font-size: 26rpx;
  font-weight: 600;
  min-width: 64rpx;
  text-align: right;
}

/* ── 掌握度大数字 ────────────────────────────────── */
.mastery-hero {
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.mastery-score-wrap {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

.mastery-score {
  font-size: 96rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
  line-height: 0.92;
}

.score-good { color: #34d399; }
.score-mid  { color: #fbbf24; }
.score-low  { color: #f87171; }

.mastery-unit {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-muted);
  line-height: 1;
  margin-bottom: 12rpx;
}

.mastery-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.mastery-sub-row {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-top: 16rpx;
}

.mastery-sub-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.mastery-sub-num {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.mastery-sub-warn {
  color: #f87171;
}

.mastery-sub-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.mastery-sub-divider {
  width: 1rpx;
  height: 40rpx;
  background: var(--border);
}

/* ── 科目掌握度分组 ──────────────────────────────── */
.mastery-group {
  padding: 24rpx;
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.group-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.group-avg {
  font-size: 26rpx;
  font-weight: 700;
}

.avg-good { color: #34d399; }
.avg-mid  { color: #fbbf24; }
.avg-low  { color: #f87171; }

.group-chapters {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.chapter-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ch-name {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ch-bar {
  width: 120rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 4rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.ch-bar-fill {
  height: 100%;
  border-radius: 4rpx;
}

.ch-pct {
  font-size: 22rpx;
  font-weight: 600;
  min-width: 56rpx;
  text-align: right;
}

/* ── AI 作战方案 ───────────────────────────────── */
.battle-plan {
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background:
    radial-gradient(circle at top right, rgba(37, 99, 235, 0.18), transparent 32%),
    linear-gradient(145deg, rgba(37, 99, 235, 0.12), rgba(15, 23, 42, 0.08));
}

.battle-plan-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.battle-plan-kicker {
  display: block;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: #93c5fd;
}

.battle-plan-topic {
  display: block;
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #eff6ff;
}

.battle-plan-badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.battle-plan-badge-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #bfdbfe;
}

.battle-plan-note {
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(239, 246, 255, 0.82);
}

.battle-plan-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.battle-plan-row {
  display: grid;
  grid-template-columns: 120rpx 1fr;
  gap: 20rpx;
  align-items: start;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.battle-plan-row-first {
  padding-top: 0;
  border-top: none;
}

.battle-plan-label {
  font-size: 24rpx;
  color: rgba(191, 219, 254, 0.78);
}

.battle-plan-value {
  font-size: 24rpx;
  line-height: 1.7;
  color: #f8fafc;
}

/* ── 进步反馈 ───────────────────────────────────── */
.progress-panel {
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.progress-summary {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.progress-insight {
  margin-top: -6rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-muted);
}

.progress-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.progress-item {
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.progress-item-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.progress-item-value {
  font-size: 36rpx;
  line-height: 1.1;
  font-weight: 700;
  color: var(--text-primary);
}

.progress-item-detail {
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.progress-milestones {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding-top: 4rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.progress-milestone {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.progress-milestone-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: #7dd3fc;
  flex-shrink: 0;
}

.progress-milestone-copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.progress-milestone-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.progress-milestone-detail {
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.tone-good {
  color: #34d399;
}

.tone-accent {
  color: #7dd3fc;
}

.tone-warn {
  color: #f87171;
}


/* ── 摸底测试入口 ────────────────────────────────── */
.assess-entry {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 24rpx; margin-top: 16rpx;
}
.assess-entry:active { opacity: 0.8; }
.assess-entry-left { display: flex; align-items: center; gap: 20rpx; }
.assess-entry-icon {
  width: 72rpx; height: 72rpx; border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(59,130,246,0.2), rgba(139,92,246,0.2));
  border: 1rpx solid rgba(99,102,241,0.25);
  display: flex; align-items: center; justify-content: center;
}
.assess-entry-icon-txt { font-size: 26rpx; font-weight: 800; color: #60a5fa; }
.assess-entry-info { display: flex; flex-direction: column; gap: 4rpx; }
.assess-entry-title { font-size: 30rpx; font-weight: 600; color: #fff; }
.assess-entry-sub { font-size: 22rpx; color: rgba(255,255,255,0.4); }
.assess-entry-arrow { font-size: 32rpx; color: rgba(255,255,255,0.3); }

/* ═══════════════════════════════════════════════
   ★ 亮色模式
   ═══════════════════════════════════════════════ */

/* ── CSS 变量覆盖 ──────────────────────────── */
.report-page.light {
  --primary-400: #5e8cff;
  --primary-500: #2f6bff;
  --primary-600: #2557d8;
  --bg-primary: linear-gradient(180deg, #f7faff 0%, #eef4ff 52%, #f8fbff 100%);
  --bg-secondary: #ffffff;
  --bg-tertiary: #eef4ff;
  --bg-card: rgba(255, 255, 255, 0.92);
  --bg-elevated: rgba(255, 255, 255, 0.98);
  --text-primary: #111827;
  --text-secondary: #334155;
  --text-tertiary: #516174;
  --text-muted: #7b8799;
  --border-subtle: rgba(219, 230, 245, 0.65);
  --border-light: #dbe6f5;
  --border-medium: #d1def4;
  --border: #dbe6f5;
  --shadow-sm: 0 6rpx 18rpx rgba(126, 147, 185, 0.08);
  --shadow-md: 0 14rpx 34rpx rgba(126, 147, 185, 0.12);
}

/* ── 导航栏 ────────────────────────────────── */
.report-page.light .nav-bar {
  background: rgba(248, 250, 255, 0.96);
  border-color: #dbe6f5;
  box-shadow: 0 10rpx 28rpx rgba(126, 147, 185, 0.10);
}

.report-page.light .overview-hero {
  background:
    radial-gradient(circle at top right, rgba(56, 189, 248, 0.16), transparent 34%),
    linear-gradient(145deg, rgba(47, 107, 255, 0.12), rgba(255, 255, 255, 0.86));
}

.report-page.light .metric-chip {
  background: rgba(255, 255, 255, 0.82);
  border-color: rgba(209, 222, 244, 0.85);
}

.report-page.light .metric-chip-warn {
  background: rgba(248, 113, 113, 0.08);
  border-color: rgba(248, 113, 113, 0.14);
}
.report-page.light .metric-chip-accent {
  background: rgba(96, 165, 250, 0.08);
  border-color: rgba(96, 165, 250, 0.16);
}
.report-page.light .nav-back:active { background: rgba(0,0,0,0.04); }
.report-page.light .nav-back-arrow { color: #4f46e5; }
.report-page.light .nav-back-txt { color: #4f46e5; }

/* ── 进度条背景 ────────────────────────────── */
.report-page.light .dim-bar { background: #edf2fb; }
.report-page.light .ch-bar { background: #edf2fb; }
.report-page.light .empty-btn {
  background: #eef4ff;
  border-color: #c6d8ff;
}
.report-page.light .empty-btn-txt { color: #2f6bff; }

/* ── 入口卡片文字 ──────────────────────────── */
.report-page.light .assess-entry-title { color: #0f172a; }
.report-page.light .assess-entry-sub { color: #7b8799; }
.report-page.light .assess-entry-arrow { color: #97a5b8; }
.report-page.light .assess-entry-icon {
  background: linear-gradient(135deg, #eef4ff, #f8fbff);
  border-color: #cfe0ff;
}
.report-page.light .assess-entry-icon-txt { color: #2f6bff; }

.report-page.light .battle-plan {
  background:
    radial-gradient(circle at top right, rgba(37, 99, 235, 0.16), transparent 32%),
    linear-gradient(145deg, rgba(47, 107, 255, 0.10), rgba(255, 255, 255, 0.92));
}

.report-page.light .battle-plan-topic {
  color: #0f172a;
}

.report-page.light .battle-plan-note {
  color: #334155;
}

.report-page.light .battle-plan-badge {
  background: rgba(47, 107, 255, 0.08);
  border-color: rgba(47, 107, 255, 0.14);
}

.report-page.light .battle-plan-badge-text,
.report-page.light .battle-plan-kicker,
.report-page.light .battle-plan-label {
  color: #2f6bff;
}

.report-page.light .battle-plan-row {
  border-color: rgba(209, 222, 244, 0.7);
}

.report-page.light .battle-plan-value {
  color: #0f172a;
}

.report-page.light .progress-item {
  background: rgba(255, 255, 255, 0.8);
  border-color: rgba(209, 222, 244, 0.85);
}

.report-page.light .progress-milestones {
  border-color: rgba(209, 222, 244, 0.7);
}
