/* empty-state 组件样式 */
.empty-card {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 40rpx; text-align: center;
}
.empty-emoji {
  font-size: 72rpx; margin-bottom: 24rpx;
}
.empty-title {
  font-size: 30rpx; font-weight: 600; color: rgba(255,255,255,0.7);
  margin-bottom: 12rpx;
}
.empty-desc {
  font-size: 24rpx; color: rgba(255,255,255,0.4);
  margin-bottom: 28rpx; max-width: 480rpx; line-height: 1.5;
}
.empty-btn {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 16rpx 40rpx; border-radius: 999rpx;
  background: rgba(59,130,246,0.15); border: 1rpx solid rgba(59,130,246,0.3);
}
.empty-btn:active { background: rgba(59,130,246,0.25); transform: scale(0.97); }
.empty-btn-txt { font-size: 26rpx; color: #60a5fa; font-weight: 500; }

/* 亮色模式 */
.empty-card.light .empty-title { color: #333; }
.empty-card.light .empty-desc { color: #888; }
.empty-card.light .empty-btn { background: #eef2ff; border-color: #c7d2fe; }
.empty-card.light .empty-btn-txt { color: #2563eb; }
