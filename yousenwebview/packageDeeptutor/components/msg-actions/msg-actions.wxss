/* msg-actions 组件样式 — 从 chat.wxss 提取 */
.msg-actions {
  display: flex; align-items: center; gap: 10rpx;
  margin-top: 10rpx; padding: 0 4rpx;
}
.msg-actions-user { justify-content: flex-end; }
.act-btn {
  width: 60rpx; height: 60rpx; border-radius: 14rpx;
  background: rgba(255,255,255,0.08);
  display: flex; align-items: center; justify-content: center;
}
.act-btn:active { background: rgba(255,255,255,0.18); }
.act-on { background: rgba(59,130,246,0.2); }
.act-sep { width: 1rpx; height: 24rpx; background: rgba(255,255,255,0.08); margin: 0 2rpx; }
.ico {
  width: 32rpx; height: 32rpx;
  background-size: 32rpx 32rpx;
  background-repeat: no-repeat;
  background-position: center;
  opacity: 0.5;
}
.act-btn:active .ico { opacity: 0.95; }
.act-on .ico { opacity: 1; }

