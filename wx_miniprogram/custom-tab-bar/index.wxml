<view class="tab-bar {{isDark?'':'light'}}" wx:if="{{!hidden}}" aria-role="tablist">
  <view
    class="tab-item {{selected === index ? 'active' : ''}}"
    wx:for="{{list}}"
    wx:key="pagePath"
    data-index="{{index}}"
    bindtap="switchTab"
    aria-role="tab"
    aria-label="{{item.text}}"
    aria-selected="{{selected === index}}"
  >
    <image
      class="tab-icon"
      src="/images/{{selected === index ? item.activeIcon : item.icon}}.png"
    />
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
