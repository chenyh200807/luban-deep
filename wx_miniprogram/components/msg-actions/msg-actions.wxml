<!-- AI 消息操作栏 -->
<view class="msg-actions" wx:if="{{role === 'ai'}}">
  <view class="act-btn {{feedback==='up'?'act-on':''}}" bindtap="onThumbUp" aria-role="button" aria-label="点赞">
    <view class="ico ico-thumbup"></view>
  </view>
  <view class="act-btn {{feedback==='down'?'act-on':''}}" bindtap="onThumbDown" aria-role="button" aria-label="点踩">
    <view class="ico ico-thumbdown"></view>
  </view>
  <view class="act-sep"></view>
  <view class="act-btn" bindtap="onCopy" aria-role="button" aria-label="复制回答">
    <view class="ico ico-copy"></view>
  </view>
  <view class="act-btn" bindtap="onRetry" aria-role="button" aria-label="重新生成">
    <view class="ico ico-retry"></view>
  </view>
</view>

<!-- 用户消息操作栏 -->
<view class="msg-actions msg-actions-user" wx:elif="{{role === 'user'}}">
  <view style="flex:1"></view>
  <view class="act-btn" bindtap="onCopy" aria-role="button" aria-label="复制消息">
    <view class="ico ico-copy"></view>
  </view>
  <view class="act-btn" bindtap="onEdit" aria-role="button" aria-label="编辑消息">
    <view class="ico ico-edit"></view>
  </view>
</view>
