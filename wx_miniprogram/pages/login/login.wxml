<!-- login.wxml — Zentra 风格登录 -->
<view class="scene {{isDark?'':'light'}}">
  <view class="sky-wash" style="{{skyWashStyle}}"></view>
  <view class="orb o1" style="{{orbStyle1}}"></view>
  <view class="orb o2" style="{{orbStyle2}}"></view>
  <view class="orb o3" style="{{orbStyle3}}"></view>

  <view class="page-shell" style="{{pageShellStyle}}"
    bindtouchstart="onPageTouchStart" bindtouchmove="onPageTouchMove"
    bindtouchend="onPageTouchEnd" bindtouchcancel="onPageTouchEnd">

    <scroll-view class="body" scroll-y enhanced="{{true}}" bounces="{{true}}" show-scrollbar="{{false}}" style="padding-top:{{statusBarHeight}}px">
      <view class="spacer"></view>

      <view class="title-row">
        <image class="title-logo" src="/images/logo-mark-white.png" mode="heightFix" />
        <text class="h-white title-main">DeepTutor</text>
      </view>
      <view class="headline">
        <text class="h-white">懂你的</text>
        <text class="h-blue">智能备考导师</text>
      </view>

      <view class="subtitle-carousel"
        bindtouchstart="onSubtitleTouchStart" bindtouchmove="onSubtitleTouchMove"
        bindtouchend="onSubtitleTouchEnd" bindtouchcancel="onSubtitleTouchEnd">
        <view class="subtitle-track" style="{{subtitleTrackStyle}}">
          <view class="subtitle-slide" wx:for="{{heroMessages}}" wx:key="index">
            <text class="subtitle">{{item.line1}}</text>
            <text class="subtitle2">{{item.line2}}</text>
          </view>
        </view>
      </view>

      <view class="dots">
        <view wx:for="{{heroMessages}}" wx:key="index"
          class="{{activeHeroIndex === index ? 'dot-active' : 'dot-idle'}}"></view>
      </view>

      <view class="form" wx:if="{{loginMode === 'phone_code'}}">
        <view class="inp-group">
          <view class="inp-icon">
            <text class="inp-icon-txt">+86</text>
          </view>
          <input class="inp inp-phone" type="number" value="{{username}}" bindinput="onUsernameInput"
            placeholder="请输入手机号" placeholder-class="ph" maxlength="11" />
        </view>
        <view class="code-row">
          <view class="inp-group code-input">
            <view class="inp-icon">
              <text class="inp-icon-shield">🔐</text>
            </view>
            <input class="inp inp-code" type="number" value="{{phoneCode}}" bindinput="onPhoneCodeInput"
              placeholder="输入验证码" placeholder-class="ph" maxlength="6" />
          </view>
          <view class="btn-send {{codeCountdown > 0 ? 'btn-send-counting' : ''}} {{loading ? 'btn-send-off' : ''}}"
            bindtap="sendCode">
            <view class="btn-send-shine" wx:if="{{codeCountdown <= 0 && !loading}}"></view>
            <text class="btn-send-txt">{{codeCountdown > 0 ? codeCountdown + 's 后重发' : '获取验证码'}}</text>
          </view>
        </view>
      </view>

      <view class="form" wx:if="{{loginMode === 'password'}}">
        <view class="inp-group">
          <view class="inp-icon"><text class="inp-icon-txt">ID</text></view>
          <input class="inp" value="{{username}}" bindinput="onUsernameInput"
            placeholder="用户名" placeholder-class="ph" maxlength="50" />
        </view>
        <view class="inp-group">
          <view class="inp-icon"><text class="inp-icon-shield">🔑</text></view>
          <input class="inp" style="flex:1;" value="{{password}}" bindinput="onPasswordInput"
            placeholder="密码" placeholder-class="ph" password="{{!showPassword}}" maxlength="128" />
          <view class="eye" bindtap="togglePassword">
            <text class="eye-txt">{{showPassword ? '隐藏' : '显示'}}</text>
          </view>
        </view>
      </view>

      <view class="action-panel" style="padding-bottom: {{safeBottom + 24}}px">
        <view class="err" wx:if="{{errorMsg}}">
          <text class="err-txt">{{errorMsg}}</text>
        </view>

        <block wx:if="{{loginMode === 'phone_code'}}">
          <button class="btn-main {{loading?'off':''}}" bindtap="verifyCode" disabled="{{loading}}">
            <view class="btn-glow" style="{{btnGlowStyle}}"></view>
            <text class="btn-txt">{{loading ? '登录中...' : '登录'}}</text>
          </button>
        </block>
        <block wx:if="{{loginMode === 'password'}}">
          <button class="btn-main {{loading?'off':''}}" bindtap="handlePasswordLogin" disabled="{{loading}}">
            <view class="btn-glow" style="{{btnGlowStyle}}"></view>
            <text class="btn-txt">{{loading ? '登录中...' : '登录'}}</text>
          </button>
        </block>

        <view class="foot">
          <block wx:if="{{loginMode === 'phone_code'}}">
            <text class="foot-link" bindtap="goRegister">注册</text>
            <text class="foot-sep">·</text>
            <text class="foot-link" bindtap="switchLoginMode">账号密码登录</text>
          </block>
          <block wx:if="{{loginMode === 'password'}}">
            <text class="foot-link" bindtap="goRegister">注册</text>
            <text class="foot-sep">·</text>
            <text class="foot-link" bindtap="switchLoginMode">手机验证码登录</text>
          </block>
        </view>
      </view>

      <view class="scroll-safe-space"></view>
    </scroll-view>
  </view>
</view>
