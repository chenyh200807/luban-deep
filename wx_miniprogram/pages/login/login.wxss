.scene {
  height: 100vh;
  background: linear-gradient(180deg, #10214c 0%, #0b1635 38%, #070d1d 72%, #04070e 100%);
  position: relative;
  overflow: hidden;
}

.page-shell {
  position: relative;
  z-index: 1;
  height: 100vh;
  width: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.sky-wash {
  position: fixed;
  inset: -8% -10% auto -10%;
  height: 70vh;
  pointer-events: none;
  z-index: 0;
  background:
    radial-gradient(circle at 18% 10%, rgba(255, 255, 255, 0.74) 0%, rgba(208, 226, 255, 0.42) 18%, rgba(122, 170, 255, 0.16) 40%, transparent 66%),
    radial-gradient(circle at 72% 58%, rgba(201, 223, 255, 0.82) 0%, rgba(157, 194, 255, 0.28) 18%, rgba(90, 142, 255, 0.10) 38%, transparent 60%),
    radial-gradient(circle at 90% 16%, rgba(55, 101, 225, 0.22) 0%, transparent 40%);
}

.orb {
  position: fixed;
  pointer-events: none;
  z-index: 0;
  border-radius: 50%;
  mix-blend-mode: screen;
  transform: translate(-50%, -50%);
}

.o1 {
  width: 860rpx;
  height: 860rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.90) 0%, rgba(232,241,255,0.56) 20%, rgba(119,162,255,0.14) 48%, transparent 72%);
}

.o2 {
  width: 760rpx;
  height: 760rpx;
  background: radial-gradient(circle, rgba(203,225,255,0.34) 0%, rgba(93,143,255,0.12) 36%, transparent 68%);
}

.o3 {
  width: 720rpx;
  height: 720rpx;
  background: radial-gradient(circle, rgba(70,120,240,0.12) 0%, transparent 66%);
}

.body {
  position: relative;
  z-index: 1;
  flex: 1;
  width: 100%;
  overflow-y: auto;
  box-sizing: border-box;
}

.hero-stage {
  width: 100%;
  min-height: calc(100vh - 40rpx);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: stretch;
  padding: 0 0 392rpx;
  box-sizing: border-box;
}

.hero-block {
  width: 590rpx;
  max-width: calc(100vw - 120rpx);
  padding: 0 36rpx;
}

.hero-kicker {
  display: block;
  margin-bottom: 14rpx;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 580;
  letter-spacing: 3.2rpx;
  text-transform: uppercase;
  color: rgba(226, 232, 240, 0.44);
  white-space: nowrap;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  opacity: 0.96;
}

.brand-mark {
  height: 44rpx;
  display: block;
}

.brand-name {
  font-size: 54rpx;
  line-height: 1;
  font-weight: 760;
  color: rgba(255, 255, 255, 0.98);
  letter-spacing: 0.4rpx;
  white-space: nowrap;
}

.hero-copy {
  margin-top: 22rpx;
  max-width: 100%;
}

.hero-line {
  display: block;
  font-weight: 780;
  letter-spacing: -1.4rpx;
}

.hero-line-single {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  white-space: nowrap;
}

.hero-line-main-inline {
  font-size: 68rpx;
  line-height: 1;
  color: #ffffff;
}

.hero-line-accent-inline {
  font-size: 68rpx;
  line-height: 1;
  color: #4d97ff;
  font-style: italic;
}

.hero-desc {
  display: block;
  margin-top: 20rpx;
  max-width: 100%;
  font-size: 22rpx;
  line-height: 1.44;
  color: rgba(226, 232, 240, 0.56);
}

.hero-desc-sub {
  margin-top: 2rpx;
}

.pager-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.pager-dot {
  border-radius: 999rpx;
}

.pager-dot-active {
  width: 36rpx;
  height: 8rpx;
  background: #4d97ff;
}

.pager-dot-idle {
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.18);
}

.action-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  padding: 32rpx 18rpx 0;
  background: linear-gradient(
    180deg,
    rgba(4, 7, 14, 0) 0%,
    rgba(4, 7, 14, 0.54) 18%,
    rgba(4, 7, 14, 0.88) 46%,
    rgba(4, 7, 14, 0.98) 100%
  );
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  z-index: 2;
}

.err {
  margin-bottom: 20rpx;
  padding: 14rpx 22rpx;
  background: rgba(127, 29, 29, 0.28);
  border: 1rpx solid rgba(239, 68, 68, 0.18);
  border-radius: 16rpx;
}

.err-txt {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #fda4af;
}

.btn-wechat-stack {
  position: relative;
  width: 100%;
  padding: 0;
  border-radius: 34rpx;
  background: linear-gradient(90deg, rgba(40, 114, 255, 0.96) 0%, rgba(92, 152, 255, 0.96) 52%, rgba(157, 193, 255, 0.92) 100%);
  box-shadow:
    0 20rpx 42rpx rgba(37, 99, 235, 0.24),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
  box-sizing: border-box;
  overflow: hidden;
}

.btn-wechat-primary {
  display: flex;
  width: 100%;
  max-width: none;
  height: 104rpx;
  border-radius: 34rpx;
  margin: 0;
  padding: 0;
  border: none;
  background: transparent;
  box-shadow: none;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.btn-wechat-primary::after {
  border: none;
}

.btn-wechat-primary:active {
  transform: scale(0.985);
  opacity: 0.92;
}

.btn-wechat-primary.off {
  opacity: 0.5;
}

.btn-wechat-primary-txt {
  font-size: 31rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.4rpx;
}

.link-row {
  width: 100%;
  margin-top: 22rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: transparent;
}

.manual-link {
  display: inline-block;
  font-size: 23rpx;
  line-height: 1.2;
  color: rgba(226, 232, 240, 0.72);
  font-weight: 560;
  text-align: center;
  background: transparent;
  padding: 0;
  border-radius: 0;
  box-shadow: none;
  margin: 0 auto;
  transform: none;
}

.scene.light {
  background: linear-gradient(180deg, #eef4ff 0%, #edf3fb 40%, #ffffff 100%);
}

.scene.light .sky-wash {
  opacity: 0.9;
}

.scene.light .orb {
  mix-blend-mode: normal;
  opacity: 0.24;
}

.scene.light .brand-mark {
  filter: brightness(0);
}

.scene.light .brand-name,
.scene.light .hero-line-main-inline {
  color: #0f172a;
}

.scene.light .hero-kicker {
  color: rgba(37, 99, 235, 0.5);
}

.scene.light .hero-line-accent-inline {
  color: #2563eb;
}

.scene.light .hero-desc {
  color: #64748b;
}

.scene.light .pager-dot-idle {
  background: rgba(100, 116, 139, 0.28);
}

.scene.light .btn-wechat-primary {
  background: linear-gradient(90deg, #2563eb 0%, #4d8fff 52%, #9dc1ff 100%);
  box-shadow: 0 14rpx 30rpx rgba(37, 99, 235, 0.16);
}

.scene.light .manual-link {
  color: #475569;
}
