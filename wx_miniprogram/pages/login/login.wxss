.scene {
  height: 100vh;
  background: linear-gradient(180deg, #10214c 0%, #0b1635 38%, #070d1d 72%, #04070e 100%);
  position: relative;
  overflow: hidden;
}

.page-shell {
  position: relative;
  z-index: 1;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.sky-wash {
  position: fixed;
  inset: -8% -10% auto -10%;
  height: 70vh;
  pointer-events: none;
  z-index: 0;
  background:
    radial-gradient(circle at 18% 10%, rgba(255, 255, 255, 0.74) 0%, rgba(208, 226, 255, 0.42) 18%, rgba(122, 170, 255, 0.16) 40%, transparent 66%),
    radial-gradient(circle at 72% 58%, rgba(201, 223, 255, 0.82) 0%, rgba(157, 194, 255, 0.28) 18%, rgba(90, 142, 255, 0.10) 38%, transparent 60%),
    radial-gradient(circle at 90% 16%, rgba(55, 101, 225, 0.22) 0%, transparent 40%);
}

.orb {
  position: fixed;
  pointer-events: none;
  z-index: 0;
  border-radius: 50%;
  mix-blend-mode: screen;
  transform: translate(-50%, -50%);
}

.o1 {
  width: 860rpx;
  height: 860rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.90) 0%, rgba(232,241,255,0.56) 20%, rgba(119,162,255,0.14) 48%, transparent 72%);
}

.o2 {
  width: 760rpx;
  height: 760rpx;
  background: radial-gradient(circle, rgba(203,225,255,0.34) 0%, rgba(93,143,255,0.12) 36%, transparent 68%);
}

.o3 {
  width: 720rpx;
  height: 720rpx;
  background: radial-gradient(circle, rgba(70,120,240,0.12) 0%, transparent 66%);
}

.body {
  position: relative;
  z-index: 1;
  flex: 1;
  overflow-y: auto;
}

.hero-top-space {
  height: 40vh;
  min-height: 500rpx;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 48rpx;
  opacity: 0.96;
}

.brand-mark {
  height: 42rpx;
  display: block;
}

.brand-name {
  font-size: 28rpx;
  line-height: 1;
  font-weight: 680;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 0.2rpx;
  white-space: nowrap;
}

.hero-copy {
  margin-top: 28rpx;
  padding: 0 48rpx;
}

.hero-kicker {
  display: block;
  margin-bottom: 22rpx;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 2.2rpx;
  text-transform: uppercase;
  color: rgba(191, 219, 254, 0.56);
}

.hero-line {
  display: block;
  font-weight: 780;
  letter-spacing: 0.2rpx;
}

.hero-line-main {
  font-size: 66rpx;
  line-height: 1.08;
  color: #ffffff;
}

.hero-line-combo {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 8rpx;
}

.hero-line-accent {
  font-size: 66rpx;
  line-height: 1.08;
  color: #4d97ff;
  font-style: italic;
}

.hero-line-tail {
  font-size: 66rpx;
  line-height: 1.08;
  color: #eef4ff;
}

.hero-desc {
  display: block;
  margin-top: 24rpx;
  max-width: 86%;
  font-size: 24rpx;
  line-height: 1.56;
  color: rgba(226, 232, 240, 0.64);
}

.hero-desc-sub {
  margin-top: 2rpx;
}

.pager-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 48rpx;
  margin-top: 22rpx;
}

.pager-dot {
  border-radius: 999rpx;
}

.pager-dot-active {
  width: 36rpx;
  height: 8rpx;
  background: #4d97ff;
}

.pager-dot-idle {
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.18);
}

.action-panel {
  padding: 64rpx 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.err {
  margin-bottom: 16rpx;
  padding: 14rpx 22rpx;
  background: rgba(127, 29, 29, 0.28);
  border: 1rpx solid rgba(239, 68, 68, 0.18);
  border-radius: 16rpx;
}

.err-txt {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #fda4af;
}

.btn-wechat-primary {
  width: 100%;
  height: 96rpx;
  border-radius: 24rpx;
  margin: 0;
  border: none;
  background: linear-gradient(90deg, #2872ff 0%, #5c98ff 52%, #9dc1ff 100%);
  box-shadow: 0 14rpx 30rpx rgba(37, 99, 235, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-wechat-primary::after {
  border: none;
}

.btn-wechat-primary:active {
  transform: scale(0.985);
  opacity: 0.92;
}

.btn-wechat-primary.off {
  opacity: 0.5;
}

.btn-wechat-primary-txt {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.6rpx;
}

.helper-row {
  margin-top: 18rpx;
  display: flex;
  justify-content: center;
}

.helper-text {
  font-size: 22rpx;
  color: rgba(226, 232, 240, 0.36);
  text-align: center;
}

.link-stack {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.secondary-link {
  font-size: 23rpx;
  color: rgba(226, 232, 240, 0.62);
}

.manual-link {
  font-size: 24rpx;
  color: #5ea3ff;
  font-weight: 600;
}

.scroll-safe-space {
  height: 48rpx;
}

.scene.light {
  background: linear-gradient(180deg, #eef4ff 0%, #edf3fb 40%, #ffffff 100%);
}

.scene.light .sky-wash {
  opacity: 0.9;
}

.scene.light .orb {
  mix-blend-mode: normal;
  opacity: 0.24;
}

.scene.light .brand-mark {
  filter: brightness(0);
}

.scene.light .brand-name,
.scene.light .hero-line-main,
.scene.light .hero-line-tail {
  color: #0f172a;
}

.scene.light .hero-kicker {
  color: rgba(37, 99, 235, 0.52);
}

.scene.light .hero-line-accent {
  color: #2563eb;
}

.scene.light .hero-desc {
  color: #64748b;
}

.scene.light .pager-dot-idle {
  background: rgba(100, 116, 139, 0.28);
}

.scene.light .btn-wechat-primary {
  background: linear-gradient(90deg, #2563eb 0%, #4d8fff 52%, #9dc1ff 100%);
  box-shadow: 0 14rpx 30rpx rgba(37, 99, 235, 0.16);
}

.scene.light .helper-text {
  color: #64748b;
}

.scene.light .secondary-link {
  color: #475569;
}

.scene.light .manual-link {
  color: #2563eb;
}
