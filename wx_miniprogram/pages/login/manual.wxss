.manual-page { min-height:100vh; background:linear-gradient(180deg,#0b1633 0%,#091127 34%,#060a16 64%,#04060b 100%); position:relative; overflow:hidden; }
.page-shell { position:relative; z-index:1; min-height:100vh; }
.sky-wash { position:fixed; top:-8%; left:-12%; right:-12%; height:62vh; pointer-events:none; z-index:0; background:radial-gradient(circle at 24% 14%,rgba(255,255,255,0.68) 0%,rgba(190,220,255,0.32) 20%,rgba(80,130,255,0.10) 38%,transparent 62%),radial-gradient(circle at 78% 16%,rgba(78,130,255,0.22) 0%,transparent 38%); }
.body { position:relative; z-index:1; min-height:100vh; }
.nav-row { padding:10rpx 28rpx 0; }
.nav-back { display:inline-flex; align-items:center; gap:8rpx; color:rgba(255,255,255,0.82); }
.nav-back-arrow { font-size:38rpx; }
.nav-back-txt { font-size:24rpx; }
.hero { padding:72rpx 44rpx 28rpx; }
.title-row { display:flex; align-items:center; gap:16rpx; }
.title-logo { height:60rpx; display:block; }
.title-main { font-size:40rpx; font-weight:760; color:#ffffff; letter-spacing:0.4rpx; white-space:nowrap; }
.hero-title { display:block; margin-top:34rpx; font-size:58rpx; line-height:1.08; font-weight:760; color:#ffffff; }
.hero-sub { display:block; margin-top:16rpx; max-width:82%; font-size:26rpx; line-height:1.62; color:rgba(226,232,240,0.58); }
.sheet { margin:18rpx 24rpx 0; padding:22rpx; border-radius:30rpx; background:rgba(8,11,20,0.86); border:1rpx solid rgba(148,163,184,0.10); box-shadow:0 20rpx 48rpx rgba(0,0,0,0.30), inset 0 1rpx 0 rgba(255,255,255,0.03); }
.mode-switch { display:flex; gap:10rpx; padding:6rpx; border-radius:999rpx; background:rgba(255,255,255,0.04); }
.mode-pill { flex:1; min-height:64rpx; border-radius:999rpx; display:flex; align-items:center; justify-content:center; }
.mode-pill-active { background:linear-gradient(135deg, rgba(59,130,246,0.30) 0%, rgba(96,165,250,0.16) 100%); box-shadow:inset 0 0 0 1rpx rgba(96,165,250,0.22); }
.mode-pill-txt { font-size:24rpx; font-weight:650; color:rgba(226,232,240,0.68); }
.mode-pill-active .mode-pill-txt { color:#eaf3ff; }
.err { margin:18rpx 0 0; padding:14rpx 18rpx; border-radius:16rpx; background:rgba(127,29,29,0.28); border:1rpx solid rgba(239,68,68,0.18); }
.err-txt { font-size:24rpx; color:#fca5a5; text-align:center; display:block; }
.manual-form { display:flex; flex-direction:column; gap:14rpx; margin-top:18rpx; }
.inp-group { display:flex; align-items:center; background:rgba(255,255,255,0.06); border:1rpx solid rgba(255,255,255,0.10); border-radius:22rpx; overflow:hidden; }
.inp-icon { display:flex; align-items:center; justify-content:center; min-width:92rpx; height:92rpx; border-right:1rpx solid rgba(255,255,255,0.06); }
.inp-icon-txt { font-size:26rpx; font-weight:600; color:rgba(255,255,255,0.45); }
.inp-icon-shield { font-size:30rpx; }
.inp { flex:1; height:92rpx; padding:0 28rpx; font-size:30rpx; color:#fff; background:transparent; border:none; box-sizing:border-box; }
.inp-phone { letter-spacing:2rpx; }
.inp-code { letter-spacing:8rpx; font-weight:500; }
.ph { color:rgba(255,255,255,0.24); font-size:28rpx; }
.code-row { display:flex; gap:12rpx; align-items:stretch; }
.code-input { flex:1; }
.btn-send { min-width:212rpx; height:92rpx; margin:0; padding:0 20rpx; border:none; border-radius:22rpx; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg, rgba(33,108,255,0.28) 0%, rgba(77,158,255,0.18) 100%); border:1rpx solid rgba(77,158,255,0.26); }
.btn-send::after { border:none; }
.btn-send-txt { font-size:26rpx; font-weight:600; color:#7db4ff; }
.btn-send-counting { background:rgba(255,255,255,0.04); border-color:rgba(255,255,255,0.08); }
.btn-send-counting .btn-send-txt { color:rgba(255,255,255,0.32); }
.btn-send-off { opacity:0.4; }
.eye { padding:0 26rpx; display:flex; align-items:center; height:92rpx; }
.eye-txt { font-size:24rpx; color:rgba(125,180,255,0.72); }
.btn-manual { width:100%; margin:4rpx 0 0; min-height:82rpx; padding:0 24rpx; border-radius:22rpx; border:none; background:rgba(255,255,255,0.06); box-shadow:inset 0 0 0 1rpx rgba(148,163,184,0.14); }
.btn-manual::after { border:none; }
.btn-manual.off { opacity:0.45; }
.btn-manual-txt { font-size:26rpx; font-weight:680; color:#f8fbff; letter-spacing:0.2rpx; white-space:nowrap; }
.foot { display:flex; justify-content:center; margin-top:18rpx; }
.foot-link { font-size:24rpx; color:#5ea3ff; }

.manual-page.light { background:linear-gradient(180deg,#eef4ff 0%,#edf3fb 36%,#ffffff 100%); }
.manual-page.light .nav-back { color:#334155; }
.manual-page.light .title-logo { filter:brightness(0); }
.manual-page.light .title-main,
.manual-page.light .hero-title { color:#0f172a; }
.manual-page.light .hero-sub { color:#64748b; }
.manual-page.light .sheet { background:rgba(255,255,255,0.88); border-color:rgba(148,163,184,0.16); box-shadow:0 20rpx 48rpx rgba(15,23,42,0.08); }
.manual-page.light .mode-switch { background:rgba(15,23,42,0.04); }
.manual-page.light .mode-pill-txt { color:#64748b; }
.manual-page.light .mode-pill-active { background:linear-gradient(135deg, rgba(37,99,235,0.12) 0%, rgba(96,165,250,0.08) 100%); box-shadow:inset 0 0 0 1rpx rgba(37,99,235,0.14); }
.manual-page.light .mode-pill-active .mode-pill-txt { color:#1d4ed8; }
.manual-page.light .inp-group { background:rgba(15,23,42,0.04); border-color:rgba(148,163,184,0.14); }
.manual-page.light .inp-icon { border-right-color:rgba(148,163,184,0.14); }
.manual-page.light .inp-icon-txt { color:#64748b; }
.manual-page.light .inp { color:#0f172a; }
.manual-page.light .ph { color:#94a3b8; }
.manual-page.light .btn-send { background:linear-gradient(135deg, rgba(37,99,235,0.12) 0%, rgba(96,165,250,0.08) 100%); border-color:rgba(37,99,235,0.18); }
.manual-page.light .btn-send-txt { color:#2563eb; }
.manual-page.light .btn-send-counting { background:rgba(15,23,42,0.03); border-color:rgba(148,163,184,0.14); }
.manual-page.light .btn-send-counting .btn-send-txt { color:#94a3b8; }
.manual-page.light .eye-txt { color:#2563eb; }
.manual-page.light .btn-manual { background:rgba(15,23,42,0.04); box-shadow:inset 0 0 0 1rpx rgba(148,163,184,0.16); }
.manual-page.light .btn-manual-txt { color:#0f172a; }
.manual-page.light .foot-link { color:#2563eb; }
