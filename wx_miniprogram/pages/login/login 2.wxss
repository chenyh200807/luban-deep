/* login.wxss */
.scene { height:100vh; background:linear-gradient(180deg,#0b1633 0%,#091127 34%,#060a16 64%,#04060b 100%); position:relative; overflow:hidden; }
.page-shell { position:relative; z-index:1; height:100vh; display:flex; flex-direction:column; }
.sky-wash { position:fixed; top:-6%; left:-10%; right:-8%; height:64vh; pointer-events:none; z-index:0; background:radial-gradient(circle at 28% 14%,rgba(80,130,255,0.34) 0%,rgba(80,130,255,0.1) 26%,transparent 58%),radial-gradient(circle at 64% 18%,rgba(236,244,255,0.26) 0%,rgba(151,195,255,0.14) 24%,transparent 56%),radial-gradient(circle at 78% 42%,rgba(66,121,255,0.2) 0%,transparent 42%); }
.orb { position:fixed; pointer-events:none; z-index:0; border-radius:50%; mix-blend-mode:screen; transform:translate(-50%,-50%); }
.o1 { width:860rpx; height:860rpx; background:radial-gradient(circle,rgba(255,255,255,1) 0%,rgba(245,250,255,0.88) 14%,rgba(160,205,255,0.52) 34%,rgba(80,145,255,0.18) 52%,transparent 70%); }
.o2 { width:790rpx; height:790rpx; background:radial-gradient(circle,rgba(240,246,255,0.72) 0%,rgba(200,222,255,0.40) 18%,rgba(90,148,255,0.16) 40%,rgba(41,90,216,0.05) 58%,transparent 74%); }
.o3 { width:740rpx; height:740rpx; background:radial-gradient(circle,rgba(220,232,255,0.48) 0%,rgba(170,200,245,0.24) 18%,rgba(75,130,230,0.10) 40%,rgba(40,80,190,0.03) 58%,transparent 74%); }
.body { position:relative; z-index:1; flex:1; overflow-y:auto; }
.spacer { height:38vh; min-height:330rpx; }
.title-row { display:flex; align-items:center; gap:18rpx; padding:0 32rpx 0 48rpx; margin-bottom:10rpx; }
.title-logo { height:66rpx; flex:0 0 auto; display:block; }
.title-main { display:block; transform:translateY(2rpx); }
.headline { padding:0 32rpx 0 48rpx; line-height:1.04; }
.h-white { font-size:68rpx; font-weight:760; color:#ffffff; letter-spacing:1rpx; }
.h-blue { font-size:68rpx; font-weight:760; color:#4d9eff; font-style:italic; letter-spacing:1rpx; }
.subtitle-carousel { position:relative; height:90rpx; margin-top:10rpx; overflow:hidden; }
.subtitle-track { display:flex; flex-direction:row; }
.subtitle-slide { flex:0 0 100%; height:90rpx; }
.subtitle,.subtitle2 { display:block; max-width:80%; padding:0 48rpx; font-size:27rpx; color:rgba(255,255,255,0.38); line-height:1.52; }
.subtitle2 { margin-top:-2rpx; }
.dots { display:flex; align-items:center; gap:10rpx; padding:0 48rpx; margin:12rpx 0 24rpx; }
.dot-active { width:40rpx; height:8rpx; border-radius:4rpx; background:#4d9eff; }
.dot-idle { width:8rpx; height:8rpx; border-radius:50%; background:rgba(255,255,255,0.2); }
.form { display:flex; flex-direction:column; gap:14rpx; padding:0 40rpx; margin-bottom:10rpx; }
.inp-group { display:flex; align-items:center; background:rgba(255,255,255,0.06); border:1rpx solid rgba(255,255,255,0.10); border-radius:22rpx; overflow:hidden; transition:border-color 0.2s; }
.inp-group:focus-within { border-color:rgba(77,158,255,0.4); background:rgba(255,255,255,0.09); }
.inp-icon { display:flex; align-items:center; justify-content:center; min-width:92rpx; height:92rpx; border-right:1rpx solid rgba(255,255,255,0.06); }
.inp-icon-txt { font-size:26rpx; font-weight:600; color:rgba(255,255,255,0.45); letter-spacing:1rpx; }
.inp-icon-shield { font-size:30rpx; }
.inp { flex:1; height:92rpx; padding:0 28rpx; font-size:30rpx; color:#fff; background:transparent; border:none; box-sizing:border-box; }
.inp-phone { letter-spacing:2rpx; }
.inp-code { letter-spacing:8rpx; font-weight:500; }
.ph { color:rgba(255,255,255,0.24); font-size:28rpx; }
.code-row { display:flex; gap:12rpx; align-items:stretch; }
.code-input { flex:1; }
.btn-send { position:relative; overflow:hidden; min-width:208rpx; height:92rpx; display:flex; align-items:center; justify-content:center; border-radius:22rpx; border:none; margin:0; padding:0 20rpx; background:linear-gradient(135deg, rgba(47,116,255,0.28) 0%, rgba(77,158,255,0.18) 100%); border:1rpx solid rgba(77,158,255,0.35); box-shadow:0 4rpx 20rpx rgba(47,116,255,0.15), inset 0 1rpx 0 rgba(255,255,255,0.08); }
.btn-send::after { border:none; }
.btn-send:active { transform:scale(0.96); opacity:0.9; }
.btn-send-txt { font-size:26rpx; font-weight:600; color:rgba(77,158,255,0.95); letter-spacing:1rpx; position:relative; z-index:1; white-space:nowrap; }
.btn-send-shine { position:absolute; top:0; left:-100%; width:100%; height:100%; background:linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.12) 50%, transparent 100%); animation:shine-sweep 2.4s ease-in-out infinite; }
@keyframes shine-sweep { 0% { left:-100%; } 60% { left:100%; } 100% { left:100%; } }
.btn-send-counting { background:rgba(255,255,255,0.04); border-color:rgba(255,255,255,0.08); box-shadow:none; }
.btn-send-counting .btn-send-txt { color:rgba(255,255,255,0.3); font-weight:400; font-variant-numeric:tabular-nums; }
.btn-send-off { opacity:0.35; }
.eye { position:static; padding:0 28rpx; display:flex; align-items:center; height:92rpx; }
.eye-txt { font-size:24rpx; color:rgba(77,158,255,0.6); font-weight:500; }
.scroll-safe-space { height:24rpx; }
.err { width:100%; margin:0 0 10rpx; padding:14rpx 24rpx; background:rgba(239,68,68,0.08); border:1rpx solid rgba(239,68,68,0.15); border-radius:16rpx; box-sizing:border-box; }
.err-txt { font-size:24rpx; color:#f87171; display:block; text-align:center; }
.action-panel { position:relative; z-index:2; padding:16rpx 40rpx 0; box-sizing:border-box; display:flex; flex-direction:column; align-items:stretch; }
.btn-wechat-primary { width:100%; margin:0; min-height:122rpx; padding:0 28rpx; border-radius:28rpx; position:relative; overflow:hidden; border:none; background:linear-gradient(135deg,#1f7aff 0%,#60a5fa 42%,#dbeafe 100%); display:flex; align-items:center; gap:22rpx; box-shadow:0 18rpx 40rpx rgba(37,99,235,0.30), 0 0 56rpx rgba(147,197,253,0.12); }
.btn-wechat-primary::after { border:none; }
.btn-wechat-primary:active { opacity:0.92; transform:scale(0.985); }
.btn-wechat-primary.off { opacity:0.52; }
.btn-wechat-primary-orb { position:absolute; top:-22%; right:-6%; width:220rpx; height:220rpx; border-radius:50%; background:radial-gradient(circle,rgba(255,255,255,0.72) 0%,rgba(255,255,255,0.18) 46%,transparent 74%); }
.btn-wechat-primary-mark { position:relative; z-index:1; width:72rpx; height:72rpx; border-radius:24rpx; background:rgba(11,19,40,0.22); backdrop-filter:blur(8rpx); display:flex; align-items:center; justify-content:center; box-shadow:inset 0 0 0 1rpx rgba(255,255,255,0.18); }
.btn-wechat-primary-mark-txt { color:#ffffff; font-size:36rpx; font-weight:800; line-height:1; }
.btn-wechat-primary-copy { position:relative; z-index:1; flex:1; display:flex; flex-direction:column; align-items:flex-start; }
.btn-wechat-primary-title { font-size:34rpx; font-weight:760; color:#ffffff; letter-spacing:0.5rpx; }
.btn-wechat-primary-sub { margin-top:8rpx; font-size:23rpx; color:rgba(239,246,255,0.84); line-height:1.5; text-align:left; }
.wechat-secondary-row { display:flex; align-items:center; justify-content:space-between; gap:16rpx; margin-top:14rpx; padding:0 6rpx; }
.wechat-secondary-tip { font-size:22rpx; color:rgba(255,255,255,0.34); }
.wechat-secondary-link { font-size:22rpx; color:rgba(147,197,253,0.88); }
.alt-panel { margin-top:22rpx; padding:22rpx 22rpx 20rpx; border-radius:28rpx; background:rgba(7,11,23,0.46); border:1rpx solid rgba(148,163,184,0.10); box-shadow:inset 0 1rpx 0 rgba(255,255,255,0.03); }
.alt-header { display:flex; align-items:flex-end; justify-content:space-between; gap:16rpx; margin-bottom:18rpx; }
.alt-title { font-size:24rpx; font-weight:700; color:#f8fbff; letter-spacing:0.4rpx; }
.alt-sub { font-size:22rpx; color:rgba(255,255,255,0.34); }
.mode-switch { display:flex; gap:10rpx; margin-bottom:18rpx; padding:6rpx; border-radius:999rpx; background:rgba(255,255,255,0.04); }
.mode-pill { flex:1; min-height:62rpx; border-radius:999rpx; display:flex; align-items:center; justify-content:center; }
.mode-pill-active { background:linear-gradient(135deg, rgba(58,111,255,0.22) 0%, rgba(96,165,250,0.16) 100%); box-shadow:inset 0 0 0 1rpx rgba(96,165,250,0.20); }
.mode-pill-txt { font-size:24rpx; color:rgba(226,232,240,0.72); font-weight:600; }
.mode-pill-active .mode-pill-txt { color:#dbeafe; }
.manual-form { display:flex; flex-direction:column; gap:12rpx; }
.btn-manual { width:100%; margin:16rpx 0 0; min-height:78rpx; border-radius:20rpx; border:none; background:rgba(255,255,255,0.06); box-shadow:inset 0 0 0 1rpx rgba(148,163,184,0.14); }
.btn-manual::after { border:none; }
.btn-manual.off { opacity:0.45; }
.btn-manual-txt { font-size:28rpx; font-weight:650; color:#e2e8f0; letter-spacing:0.4rpx; }
.foot { display:flex; flex-direction:row; justify-content:center; align-items:center; flex-wrap:wrap; gap:12rpx; margin-top:16rpx; margin-bottom:0; }
.foot-sep { font-size:22rpx; color:rgba(255,255,255,0.18); }
.foot-link { font-size:24rpx; color:rgba(77,158,255,0.78); font-weight:500; letter-spacing:0.5rpx; }

.scene.light { background:linear-gradient(180deg,#f0f4ff 0%,#e8edf8 34%,#f5f7fc 64%,#ffffff 100%); }
.scene.light .sky-wash { opacity:0.22; }
.scene.light .orb { mix-blend-mode:normal; opacity:0.28; }
.scene.light .h-white { color:#0f172a; }
.scene.light .h-blue { color:#2f6bff; }
.scene.light .title-logo { filter:brightness(0); }
.scene.light .subtitle,
.scene.light .subtitle2 { color:#64748b; }
.scene.light .dot-active { background:#2f6bff; }
.scene.light .dot-idle { background:rgba(148,163,184,0.42); }
.scene.light .inp-group { background:rgba(255,255,255,0.82); border-color:#dbe6f5; box-shadow:0 6rpx 20rpx rgba(126,147,185,0.08); }
.scene.light .inp-group:focus-within { border-color:rgba(47,107,255,0.4); background:rgba(255,255,255,0.92); }
.scene.light .inp-icon { border-right-color:rgba(0,0,0,0.06); }
.scene.light .inp-icon-txt { color:#64748b; }
.scene.light .inp { color:#0f172a; background:transparent; }
.scene.light .ph { color:#94a3b8; }
.scene.light .eye-txt { color:#2f6bff; }
.scene.light .btn-send { background:linear-gradient(135deg, rgba(47,107,255,0.12) 0%, rgba(96,165,250,0.08) 100%); border-color:rgba(47,107,255,0.3); box-shadow:0 4rpx 16rpx rgba(47,107,255,0.10); }
.scene.light .btn-send-txt { color:#2f6bff; }
.scene.light .btn-send-counting { background:rgba(0,0,0,0.03); border-color:#e2e8f0; }
.scene.light .btn-send-counting .btn-send-txt { color:#94a3b8; }
.scene.light .btn-send-shine { background:linear-gradient(90deg, transparent 0%, rgba(47,107,255,0.08) 50%, transparent 100%); }
.scene.light .err { background:rgba(239,68,68,0.06); border-color:rgba(239,68,68,0.12); }
.scene.light .btn-wechat-primary { background:linear-gradient(135deg,#2563eb 0%,#60a5fa 48%,#eff6ff 100%); box-shadow:0 16rpx 38rpx rgba(37,99,235,0.22), 0 0 50rpx rgba(147,197,253,0.10); }
.scene.light .btn-wechat-primary-mark { background:rgba(15,23,42,0.16); }
.scene.light .wechat-secondary-tip { color:#64748b; }
.scene.light .wechat-secondary-link { color:#2563eb; }
.scene.light .alt-panel { background:rgba(255,255,255,0.78); border-color:rgba(148,163,184,0.16); box-shadow:0 10rpx 28rpx rgba(15,23,42,0.05); }
.scene.light .alt-title { color:#0f172a; }
.scene.light .alt-sub { color:#64748b; }
.scene.light .mode-switch { background:rgba(15,23,42,0.04); }
.scene.light .mode-pill-txt { color:#64748b; }
.scene.light .mode-pill-active { background:linear-gradient(135deg, rgba(37,99,235,0.12) 0%, rgba(96,165,250,0.10) 100%); box-shadow:inset 0 0 0 1rpx rgba(37,99,235,0.14); }
.scene.light .mode-pill-active .mode-pill-txt { color:#1d4ed8; }
.scene.light .btn-manual { background:rgba(15,23,42,0.04); box-shadow:inset 0 0 0 1rpx rgba(148,163,184,0.16); }
.scene.light .btn-manual-txt { color:#0f172a; }
.scene.light .foot-sep { color:rgba(100,116,139,0.32); }
.scene.light .foot-link { color:#2f6bff; }
