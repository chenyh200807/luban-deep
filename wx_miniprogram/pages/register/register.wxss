/* register.wxss */
.scene { height:100vh; background:linear-gradient(180deg,#0b1633 0%,#091127 34%,#060a16 64%,#04060b 100%); position:relative; overflow:hidden; }
.page-shell { position:relative; z-index:1; height:100vh; display:flex; flex-direction:column; }
.sky-wash { position:fixed; top:-6%; left:-10%; right:-8%; height:64vh; pointer-events:none; z-index:0; background:radial-gradient(circle at 28% 14%,rgba(80,130,255,0.34) 0%,rgba(80,130,255,0.1) 26%,transparent 58%),radial-gradient(circle at 64% 18%,rgba(236,244,255,0.26) 0%,rgba(151,195,255,0.14) 24%,transparent 56%),radial-gradient(circle at 78% 42%,rgba(66,121,255,0.2) 0%,transparent 42%); }
.body { position:relative; z-index:1; flex:1; overflow-y:auto; }
.spacer { height:38vh; min-height:330rpx; }
.title-row { display:flex; align-items:center; gap:18rpx; padding:0 32rpx 0 48rpx; margin-bottom:10rpx; }
.title-logo { height:66rpx; flex:0 0 auto; display:block; }
.title-main { display:block; transform:translateY(2rpx); }
.headline { padding:0 32rpx 0 48rpx; line-height:1.04; }
.h-white { font-size:68rpx; font-weight:760; color:#ffffff; letter-spacing:1rpx; }
.h-blue { font-size:68rpx; font-weight:760; color:#4d9eff; font-style:italic; letter-spacing:1rpx; }
.subtitle-wrap { padding:12rpx 48rpx 0; }
.subtitle { display:block; max-width:80%; font-size:27rpx; color:rgba(255,255,255,0.38); line-height:1.52; }
.form { display:flex; flex-direction:column; gap:14rpx; padding:28rpx 40rpx 0; margin-bottom:10rpx; }
.inp-group { display:flex; align-items:center; background:rgba(255,255,255,0.06); border:1rpx solid rgba(255,255,255,0.10); border-radius:22rpx; overflow:hidden; }
.inp-icon { display:flex; align-items:center; justify-content:center; min-width:92rpx; height:92rpx; border-right:1rpx solid rgba(255,255,255,0.06); }
.inp-icon-txt { font-size:26rpx; font-weight:600; color:rgba(255,255,255,0.45); letter-spacing:1rpx; }
.inp-icon-shield { font-size:30rpx; }
.inp { flex:1; height:92rpx; padding:0 28rpx; font-size:30rpx; color:#fff; background:transparent; border:none; box-sizing:border-box; }
.inp-phone { letter-spacing:2rpx; }
.inp-code { letter-spacing:8rpx; font-weight:500; }
.ph { color:rgba(255,255,255,0.24); font-size:28rpx; }
.code-row { display:flex; gap:12rpx; align-items:stretch; }
.code-input { flex:1; }
.btn-send { min-width:208rpx; height:92rpx; margin:0; padding:0 20rpx; border:none; border-radius:22rpx; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg, rgba(47,116,255,0.28) 0%, rgba(77,158,255,0.18) 100%); border:1rpx solid rgba(77,158,255,0.35); box-shadow:0 4rpx 20rpx rgba(47,116,255,0.15), inset 0 1rpx 0 rgba(255,255,255,0.08); }
.btn-send::after { border:none; }
.btn-send-txt { font-size:26rpx; font-weight:600; color:rgba(77,158,255,0.95); letter-spacing:1rpx; white-space:nowrap; }
.btn-send-counting { background:rgba(255,255,255,0.04); border-color:rgba(255,255,255,0.08); box-shadow:none; }
.btn-send-counting .btn-send-txt { color:rgba(255,255,255,0.3); font-weight:400; }
.btn-send-off { opacity:0.35; }
.action-panel { position:relative; z-index:2; padding:16rpx 40rpx 0; box-sizing:border-box; display:flex; flex-direction:column; align-items:stretch; }
.err { width:100%; margin:0 0 10rpx; padding:14rpx 24rpx; background:rgba(239,68,68,0.08); border:1rpx solid rgba(239,68,68,0.15); border-radius:16rpx; box-sizing:border-box; }
.err-txt { font-size:24rpx; color:#f87171; display:block; text-align:center; }
.cta-row { display:flex; align-items:center; gap:12rpx; }
.btn-ghost { width:196rpx; height:88rpx; margin:0; border:none; border-radius:22rpx; background:rgba(255,255,255,0.05); color:rgba(255,255,255,0.82); font-size:29rpx; font-weight:600; letter-spacing:1rpx; box-shadow:inset 0 0 0 1rpx rgba(255,255,255,0.08); }
.btn-ghost::after { border:none; }
.btn-main { flex:1; height:88rpx; margin:0; border:none; border-radius:22rpx; position:relative; overflow:hidden; background:linear-gradient(90deg,#2f74ff 0%,#438dff 22%,#7fc8ff 50%,#438dff 78%,#2f74ff 100%); display:flex; align-items:center; justify-content:center; box-shadow:0 8rpx 28rpx rgba(47,116,255,0.28),0 0 42rpx rgba(122,214,255,0.14); }
.btn-main::after { border:none; }
.btn-main.off { opacity:0.45; }
.btn-txt { font-size:31rpx; font-weight:600; color:#fff; letter-spacing:1rpx; }
.foot { display:flex; flex-direction:row; justify-content:center; align-items:center; margin-top:14rpx; }
.foot-link { font-size:24rpx; color:rgba(77,158,255,0.78); font-weight:500; }
.scroll-safe-space { height:24rpx; }

.scene.light { background:linear-gradient(180deg,#f0f4ff 0%,#e8edf8 34%,#f5f7fc 64%,#ffffff 100%); }
.scene.light .h-white { color:#0f172a; }
.scene.light .h-blue { color:#2f6bff; }
.scene.light .title-logo { filter:brightness(0); }
.scene.light .subtitle { color:#64748b; }
.scene.light .inp-group { background:rgba(255,255,255,0.82); border-color:#dbe6f5; box-shadow:0 6rpx 20rpx rgba(126,147,185,0.08); }
.scene.light .inp-icon { border-right-color:rgba(0,0,0,0.06); }
.scene.light .inp-icon-txt { color:#64748b; }
.scene.light .inp { color:#0f172a; background:transparent; }
.scene.light .ph { color:#94a3b8; }
.scene.light .btn-send { background:linear-gradient(135deg, rgba(47,107,255,0.12) 0%, rgba(96,165,250,0.08) 100%); border-color:rgba(47,107,255,0.3); box-shadow:0 4rpx 16rpx rgba(47,107,255,0.10); }
.scene.light .btn-send-txt { color:#2f6bff; }
.scene.light .btn-send-counting { background:rgba(0,0,0,0.03); border-color:#e2e8f0; }
.scene.light .err { background:rgba(239,68,68,0.06); border-color:rgba(239,68,68,0.12); }
.scene.light .btn-ghost { background:rgba(255,255,255,0.82); color:#334155; box-shadow:inset 0 0 0 1rpx #dbe6f5, 0 6rpx 16rpx rgba(126,147,185,0.06); }
.scene.light .btn-main { background:linear-gradient(90deg,#2557d8 0%,#2f6bff 22%,#7db4ff 50%,#2f6bff 78%,#2557d8 100%); box-shadow:0 10rpx 34rpx rgba(47,107,255,0.22),0 0 40rpx rgba(96,165,250,0.12); }
.scene.light .foot-link { color:#2f6bff; }
