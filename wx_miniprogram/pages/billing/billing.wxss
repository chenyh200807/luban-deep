/* pages/billing/billing.wxss — 积分充值 */

.billing-page { height: 100vh; background: #080c18; overflow: hidden; }

/* ── 导航栏 ─────────────────────────────── */
.nav-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 50;
  background: rgba(8,12,24,0.9);
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.nav-content {
  height: 88rpx; display: flex; align-items: center; padding: 0 24rpx; gap: 12rpx;
}
.nav-back-pill {
  padding: 10rpx 20rpx 10rpx 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.12);
}
.nav-back-pill:active { background: rgba(255,255,255,0.16); }
.nav-back-arrow {
  font-size: 28rpx;
  line-height: 1;
  color: rgba(255,255,255,0.78);
}
.nav-back-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.78);
}
.nav-logo { height: 100rpx; margin-left: 28rpx; }

.page-scroll { position: fixed; left: 0; right: 0; overflow-y: auto; }
.page-inner { padding: 20rpx 24rpx 0; display: flex; flex-direction: column; gap: 16rpx; }

/* ── Demo 提示 ──────────────────────────── */
.demo-banner {
  padding: 12rpx 24rpx; border-radius: 12rpx;
  background: rgba(245,158,11,0.1); border: 1rpx solid rgba(245,158,11,0.2);
  text-align: center;
}
.demo-txt { font-size: 22rpx; color: #f59e0b; }

/* ── 余额卡片 ──────────────────────────── */
.balance-card {
  padding: 40rpx 32rpx; border-radius: 20rpx;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  background: linear-gradient(135deg, rgba(99,102,241,0.15), rgba(59,130,246,0.1));
  border: 1rpx solid rgba(99,102,241,0.15);
}
.balance-label { font-size: 24rpx; color: rgba(255,255,255,0.45); }
.balance-row { display: flex; align-items: center; gap: 10rpx; }
.balance-star { font-size: 44rpx; color: #f59e0b; }
.balance-num { font-size: 80rpx; font-weight: 800; color: #fff; font-variant-numeric: tabular-nums; }
.balance-hint { font-size: 22rpx; color: rgba(255,255,255,0.35); margin-top: 4rpx; }

/* ── 分区标题 ──────────────────────────── */
.section-title {
  display: block; font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.7);
  padding: 16rpx 8rpx 8rpx;
}

/* ── 套餐网格 — 2×2 ────────────────────── */
.pkg-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx;
}
.pkg-card {
  padding: 28rpx 20rpx; border-radius: 16rpx;
  background: rgba(255,255,255,0.04); border: 2rpx solid rgba(255,255,255,0.08);
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
  position: relative; transition: border-color 0.15s, background 0.15s;
}
.pkg-card:active { border-color: rgba(59,130,246,0.4); }
.pkg-card.sel {
  border-color: #3b82f6; background: rgba(59,130,246,0.08);
  box-shadow: 0 0 0 1rpx #3b82f6;
}
.pkg-badge {
  position: absolute; top: -1rpx; right: 20rpx;
  padding: 4rpx 16rpx; border-radius: 0 0 10rpx 10rpx;
  background: #f59e0b; font-size: 20rpx; font-weight: 700; color: #000;
}
.pkg-points { font-size: 48rpx; font-weight: 800; color: #fff; }
.pkg-unit { font-size: 22rpx; color: rgba(255,255,255,0.4); margin-top: -2rpx; }
.pkg-price-row { display: flex; align-items: baseline; gap: 2rpx; margin-top: 8rpx; }
.pkg-yen { font-size: 24rpx; color: #f59e0b; font-weight: 600; }
.pkg-price { font-size: 40rpx; color: #f59e0b; font-weight: 800; }
.pkg-per { font-size: 20rpx; color: rgba(255,255,255,0.3); margin-top: 2rpx; }

/* ── 充值按钮 ──────────────────────────── */
.recharge-btn {
  margin-top: 8rpx; padding: 24rpx; border-radius: 16rpx;
  background: rgba(255,255,255,0.06);
  display: flex; align-items: center; justify-content: center;
  transition: background 0.2s;
}
.recharge-btn.on { background: #2563eb; }
.recharge-btn.disabled {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
}
.recharge-btn:active { opacity: 0.85; }
.recharge-btn-txt { font-size: 30rpx; font-weight: 700; color: rgba(255,255,255,0.3); }
.recharge-btn.on .recharge-btn-txt { color: #fff; }
.recharge-btn.disabled .recharge-btn-txt { color: rgba(255,255,255,0.46); }

/* ── 骨架屏 ────────────────────────────── */
.loading-wrap { display: flex; flex-direction: column; gap: 12rpx; }
.skel-item {
  padding: 24rpx; border-radius: 14rpx;
  background: rgba(255,255,255,0.03);
}
.skel-block {
  border-radius: 6rpx;
  background: rgba(255,255,255,0.06);
  animation: shimmer 1.5s infinite;
}
@keyframes shimmer {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.8; }
}

/* ── 空/错误 ───────────────────────────── */
.empty-card {
  padding: 56rpx 32rpx; border-radius: 14rpx;
  background: rgba(255,255,255,0.03);
  display: flex; flex-direction: column; align-items: center; gap: 16rpx;
}
.empty-title { font-size: 28rpx; color: rgba(255,255,255,0.5); }
.retry-btn {
  padding: 12rpx 40rpx; border-radius: 999rpx;
  background: rgba(99,102,241,0.15); border: 1rpx solid rgba(99,102,241,0.3);
}
.retry-btn-txt { font-size: 26rpx; font-weight: 600; color: #818cf8; }

/* ── 流水列表 ──────────────────────────── */
.ledger-list { display: flex; flex-direction: column; gap: 2rpx; }
.ledger-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 22rpx 16rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}
.ledger-left { display: flex; flex-direction: column; gap: 4rpx; }
.ledger-reason { font-size: 28rpx; color: rgba(255,255,255,0.8); }
.ledger-time { font-size: 22rpx; color: rgba(255,255,255,0.3); }
.ledger-delta { font-size: 30rpx; font-weight: 700; font-variant-numeric: tabular-nums; }
.ledger-delta.debit { color: #f87171; }
.ledger-delta.credit { color: #34d399; }

/* ── 分页控件 ──────────────────────────── */
.pager-bar {
  display: flex; align-items: center; justify-content: center;
  gap: 20rpx; padding: 24rpx 16rpx; margin-top: 12rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
}
.pager-btn-wrap {
  display: flex; align-items: center; gap: 6rpx;
  padding: 16rpx 28rpx; border-radius: 12rpx;
  background: rgba(59,130,246,0.15);
  border: 1rpx solid rgba(59,130,246,0.3);
  transition: opacity 0.15s;
}
.pager-btn-wrap:active { opacity: 0.7; }
.pager-btn-wrap.disabled {
  opacity: 0.25; background: rgba(255,255,255,0.04);
  border-color: rgba(255,255,255,0.06);
}
.pager-chevron {
  font-size: 32rpx; font-weight: 700; color: #60a5fa;
  line-height: 1;
}
.pager-label {
  font-size: 26rpx; font-weight: 600; color: #60a5fa;
}
.pager-btn-wrap.disabled .pager-chevron,
.pager-btn-wrap.disabled .pager-label { color: rgba(255,255,255,0.2); }
.pager-indicator {
  min-width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 14rpx;
  background: rgba(59,130,246,0.1);
  border: 1rpx solid rgba(59,130,246,0.2);
}
.pager-page-num {
  font-size: 28rpx; font-weight: 800; color: #93c5fd;
  font-variant-numeric: tabular-nums;
}

/* ══ Light Mode ══════════════════════════════ */
.billing-page.light {
  background: linear-gradient(180deg, #f7faff 0%, #eef4ff 52%, #f8fbff 100%);
}

/* ── 导航栏 ─────────────────────────────── */
.billing-page.light .nav-bar {
  background: rgba(248,250,255,0.96);
  border-bottom-color: #dbe6f5;
  box-shadow: 0 10rpx 28rpx rgba(126,147,185,0.10);
}
.billing-page.light .nav-back-pill {
  background: rgba(255,255,255,0.82);
  border-color: rgba(148,163,184,0.24);
  box-shadow: 0 10rpx 24rpx rgba(148,163,184,0.14);
}
.billing-page.light .nav-back-arrow,
.billing-page.light .nav-back-label { color: #334155; }
.billing-page.light .nav-logo { filter: brightness(0); }

/* ── Demo 提示 ──────────────────────────── */
.billing-page.light .demo-banner {
  background: #fff6e6;
  border-color: #f7cf8c;
}
.billing-page.light .demo-txt { color: #b45309; }

/* ── 余额卡片 ──────────────────────────── */
.billing-page.light .balance-card {
  background: linear-gradient(135deg, rgba(255,255,255,0.96), rgba(238,244,255,0.92));
  border-color: #d5e1fb;
  box-shadow: 0 18rpx 42rpx rgba(126,147,185,0.14);
}
.billing-page.light .balance-label { color: #64748b; }
.billing-page.light .balance-num { color: #0f172a; }
.billing-page.light .balance-hint { color: #7b8799; }

/* ── 分区标题 ──────────────────────────── */
.billing-page.light .section-title { color: #334155; }

/* ── 套餐卡片 ──────────────────────────── */
.billing-page.light .pkg-card {
  background: rgba(255,255,255,0.92);
  border-color: #dbe6f5;
  box-shadow: 0 10rpx 28rpx rgba(126,147,185,0.08);
}
.billing-page.light .pkg-card:active { border-color: #c6d8ff; }
.billing-page.light .pkg-card.sel {
  border-color: #2f6bff;
  background: #eef4ff;
  box-shadow: 0 0 0 1rpx #2f6bff, 0 14rpx 34rpx rgba(47,107,255,0.12);
}
.billing-page.light .pkg-points { color: #0f172a; }
.billing-page.light .pkg-unit { color: #8b98ad; }
.billing-page.light .pkg-per { color: #8b98ad; }

/* ── 充值按钮 ──────────────────────────── */
.billing-page.light .recharge-btn {
  background: #e8efff;
  border: 1rpx solid #d4e1fa;
}
.billing-page.light .recharge-btn-txt { color: #7b8da8; }
.billing-page.light .recharge-btn.on { background: #2f6bff; border-color: #2f6bff; }
.billing-page.light .recharge-btn.on .recharge-btn-txt { color: #fff; }
.billing-page.light .recharge-btn.disabled {
  background: #f1f5f9;
  border-color: #dbe6f5;
}
.billing-page.light .recharge-btn.disabled .recharge-btn-txt { color: #64748b; }

/* ── 骨架屏 ────────────────────────────── */
.billing-page.light .skel-item {
  background: rgba(255,255,255,0.88);
  border: 1rpx solid #dbe6f5;
  box-shadow: 0 10rpx 24rpx rgba(153,168,197,0.08);
}
.billing-page.light .skel-block {
  background: #e6edf8;
}

/* ── 空/错误 ───────────────────────────── */
.billing-page.light .empty-card {
  background: rgba(255,255,255,0.88);
  border: 1rpx solid #dbe6f5;
  box-shadow: 0 14rpx 34rpx rgba(126,147,185,0.10);
}
.billing-page.light .empty-title { color: #8b98ad; }
.billing-page.light .retry-btn {
  background: #eef4ff;
  border-color: #c6d8ff;
}
.billing-page.light .retry-btn-txt { color: #2f6bff; }

/* ── 流水列表 ──────────────────────────── */
.billing-page.light .ledger-item {
  border-bottom-color: #e6edf8;
}
.billing-page.light .ledger-reason { color: #0f172a; }
.billing-page.light .ledger-time { color: #8b98ad; }
.billing-page.light .ledger-delta.debit { color: #dc2626; }
.billing-page.light .ledger-delta.credit { color: #16a34a; }

/* ── 分页控件 Light ─────────────────────── */
.billing-page.light .pager-bar {
  background: rgba(255,255,255,0.8);
  border-color: #dbe6f5;
  box-shadow: 0 8rpx 20rpx rgba(126,147,185,0.08);
}
.billing-page.light .pager-btn-wrap {
  background: #e8f0ff; border-color: #c0d4f7;
}
.billing-page.light .pager-btn-wrap.disabled {
  background: #f1f5f9; border-color: #e2e8f0;
}
.billing-page.light .pager-chevron { color: #2563eb; }
.billing-page.light .pager-label { color: #2563eb; }
.billing-page.light .pager-btn-wrap.disabled .pager-chevron,
.billing-page.light .pager-btn-wrap.disabled .pager-label { color: #c0cfe0; }
.billing-page.light .pager-indicator {
  background: #eef4ff; border-color: #d5e1fb;
}
.billing-page.light .pager-page-num { color: #2563eb; }
