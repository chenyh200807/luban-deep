<!-- chat.wxml — 1:1 复刻 Web 手机端 -->
<wxs module="feedbackTag">
function has(tags, tag) {
  if (!tags || !tag) return false;
  for (var i = 0; i < tags.length; i++) {
    if (tags[i] === tag) return true;
  }
  return false;
}
module.exports = {
  has: has
};
</wxs>
<view class="page {{isDark?'':'light'}}">

  <!-- 呼吸极光背景（低端设备跳过以节省 GPU） -->
  <view class="aurora-layer" wx:if="{{enableOrbs}}">
    <view class="orb orb1"></view>
    <view class="orb orb2"></view>
    <view class="orb orb3"></view>
    <view class="orb orb4"></view>
  </view>
  <image class="bg-horizon" src="/images/bg_horizon.jpg" mode="aspectFill" />

  <!-- 顶栏 — 仅 logo + 新对话 -->
  <view class="navbar {{hasMessages ? 'navbar-chat' : ''}}" style="padding-top:{{statusBarHeight}}px">
    <view class="navbar-inner" style="padding-right:{{navRightInset}}px">
      <image class="nav-logo {{hasMessages ? 'nav-logo-chat' : ''}}" src="/images/logo-white.png" mode="heightFix" bindtap="goHome" aria-role="button" aria-label="回到首页" />
      <view class="nav-back-pill" wx:if="{{hasMessages}}" bindtap="onNavBackTap" aria-role="button" aria-label="返回首页">
        <text class="nav-back-arrow">‹</text>
        <text class="nav-back-label">返回首页</text>
      </view>
      <view style="flex:1"></view>
      <view class="nav-points-pill" wx:if="{{!hasMessages}}" bindtap="goBilling" aria-role="button" aria-label="积分明细: {{userPoints}} 点">
        <text class="nav-points-star">★</text>
        <text class="nav-points-num">{{userPoints}}</text>
      </view>
      <view class="nav-chat-actions" wx:if="{{hasMessages}}">
        <view class="nav-icon-btn nav-new-chat" bindtap="clearMessages" aria-role="button" aria-label="新建对话">
          <view class="nav-compose-icon"></view>
        </view>
        <view class="nav-icon-btn nav-more-chat" bindtap="onChatMoreActions" aria-role="button" aria-label="更多对话操作">
          <text class="nav-more-icon">•••</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ★ Hero 状态 -->
  <scroll-view class="content hero-scroll" scroll-y enhanced="{{true}}" bounces="{{true}}" show-scrollbar="{{false}}" wx:if="{{!hasMessages}}" style="top:{{navHeight}}px;height:{{contentHeight}}px;"
    bindtouchstart="_onHeroDragStart" bindtouchmove="_onHeroDragMove" bindtouchend="_onHeroDragEnd" bindtouchcancel="_onHeroDragEnd">
    <view class="hero-inner" style="transform:translateY({{_heroDragY}}px);transition:{{_heroDragTransition}}">

    <!-- 用户信息行 -->
    <view class="user-row">
      <view class="hero-more-btn" bindtap="onHeroMoreActions" aria-role="button" aria-label="更多操作">
        <text class="hero-more-dot">•••</text>
      </view>
    </view>

    <!-- 撑开空间，把内容推到中下部 -->
    <view class="hero-spacer"></view>

    <!-- 问候 -->
    <view class="greeting">
      <text class="greeting-name" wx:if="{{userName && userName !== '用户'}}">{{userName}}, </text>
      <text class="greeting-time">{{timeGreeting}}</text>
    </view>
    <text class="greeting-sub">{{reviewCount > 0 ? '今天有 ' + reviewCount + ' 个逾期复习，TutorBot 已准备好带你过一遍' : '你的 TutorBot 已上线，随时开始今天的备考'}}</text>

    <!-- 今日焦点 -->
    <view class="focus-bar focus-bar-{{focusTone}} {{enableFocusPulse?'':'no-pulse'}}" wx:if="{{focusTitle || focusText}}" bindtap="onFocusTap">
      <view class="focus-icon-wrap">
        <text class="focus-icon">⚡</text>
      </view>
      <view class="focus-copy">
        <text class="focus-label">{{focusLabel}}</text>
        <text class="focus-title">{{focusTitle ? focusTitle : focusText}}</text>
        <text class="focus-meta" wx:if="{{focusMeta}}">{{focusMeta}}</text>
      </view>
      <view class="focus-next" catchtap="onFocusTap">
        <text class="focus-arrow">›</text>
      </view>
    </view>

    <!-- 输入卡片 -->
    <view class="input-card">
      <textarea
        class="input-field"
        value="{{inputText}}"
        bindinput="onInput"
        bindconfirm="sendMessage"
        placeholder="问你的 TutorBot：考点、真题、规范、错题都可以"
        placeholder-class="input-ph"
        auto-height
        maxlength="2000"
        confirm-type="send"
        show-confirm-bar="{{false}}"
        adjust-position="{{true}}"
        cursor-spacing="{{inputCursorSpacing}}"
        bindfocus="onKeyboardFocus"
        bindblur="onKeyboardBlur"
      />
	      <view class="input-bottom">
	        <view class="mode-row">
	          <view class="mode-pill {{answerMode==='AUTO'?'on':''}}" bindtap="onMode" data-m="AUTO"><text class="mode-pill-txt">智能</text></view>
	          <view class="mode-pill {{answerMode==='DEEP'?'on':''}}" bindtap="onMode" data-m="DEEP"><text class="mode-pill-txt">深度</text></view>
	          <view class="mode-pill {{answerMode==='FAST'?'on':''}}" bindtap="onMode" data-m="FAST"><text class="mode-pill-txt">快速</text></view>
	          <text class="mode-hint">{{modeHintText}}</text>
	        </view>
	        <view class="send-btn {{inputText ? 'on' : ''}}" bindtap="sendMessage" aria-role="button" aria-label="发送消息">
	          <text class="send-icon">▶</text>
	        </view>
	      </view>
	      <view class="tool-row">
	        <view class="tool-chip {{enableReason ? 'on' : ''}}" bindtap="onToggleReason" aria-role="button" aria-label="{{enableReason ? '关闭推理' : '开启推理'}}">
	          <text class="tool-chip-icon">◎</text>
	          <text class="tool-chip-txt">推理</text>
	        </view>
	        <text class="tool-hint">知识库检索默认自动开启，联网搜索暂未开放</text>
	      </view>
	    </view>

    <!-- 示例 -->
    <text class="example-label">试试这样问</text>
    <!-- 高/中端：空闲自动巡航，触摸时可手动拖动 -->
    <scroll-view class="example-scroll" wx:if="{{enableMarquee}}" scroll-x enhanced="{{true}}" bounces="{{true}}" show-scrollbar="{{false}}">
      <view class="example-scroll-track">
        <view class="example-scroll-group">
          <view class="example-card" wx:for="{{examples}}" wx:key="title" bindtap="sendExample" data-text="{{item.query}}">
            <view class="example-icon" style="background:{{isDark ? item.bgDark : item.bgLight}};color:{{isDark ? item.fgDark : item.fgLight}}">
              <text class="example-icon-txt">{{item.icon}}</text>
            </view>
            <view class="example-body">
              <text class="example-title">{{item.title}}</text>
              <text class="example-desc">{{item.desc}}</text>
            </view>
          </view>
        </view>
        <view class="example-scroll-group">
          <view class="example-card" wx:for="{{examples}}" wx:key="title" bindtap="sendExample" data-text="{{item.query}}">
            <view class="example-icon" style="background:{{isDark ? item.bgDark : item.bgLight}};color:{{isDark ? item.fgDark : item.fgLight}}">
              <text class="example-icon-txt">{{item.icon}}</text>
            </view>
            <view class="example-body">
              <text class="example-title">{{item.title}}</text>
              <text class="example-desc">{{item.desc}}</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
    <!-- 低端：静态网格 -->
    <view class="example-grid" wx:else>
      <view class="example-card" wx:for="{{examples}}" wx:key="title" bindtap="sendExample" data-text="{{item.query}}">
        <view class="example-icon" style="background:{{isDark ? item.bgDark : item.bgLight}};color:{{isDark ? item.fgDark : item.fgLight}}">
          <text class="example-icon-txt">{{item.icon}}</text>
        </view>
        <view class="example-body">
          <text class="example-title">{{item.title}}</text>
          <text class="example-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view style="height:120rpx"></view>
    </view>
  </scroll-view>

  <!-- ★ Chat 状态 -->
  <scroll-view
    class="content"
    scroll-y
    enhanced="{{true}}"
    bounces="{{true}}"
    show-scrollbar="{{false}}"
    scroll-into-view="{{scrollToId}}"
    scroll-with-animation="{{chatScrollWithAnimation}}"
    lower-threshold="120"
    wx:else
    style="top:{{navHeight}}px;height:{{contentHeight}}px;"
    bindscroll="_onChatScroll"
    bindscrolltolower="_onChatScrollToLower"
  >
    <view class="msg-list">
      <view class="msg {{item.role}} {{enableMsgAnim?'':'no-anim'}}" wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}">

        <!-- 用户消息 -->
        <view class="bubble-user" wx:if="{{item.role === 'user'}}">
          <text class="user-text" selectable>{{item.content}}</text>
          <view class="user-bar">
            <view style="flex:1"></view>
            <view class="ub-btn" bindtap="onCopy" data-msgid="{{item.id}}" aria-role="button" aria-label="复制消息">
              <view class="ico ico-copy"></view>
            </view>
            <view class="ub-btn" bindtap="onEdit" data-msgid="{{item.id}}" aria-role="button" aria-label="编辑消息">
              <view class="ico ico-edit"></view>
            </view>
          </view>
        </view>

        <!-- AI 消息 -->
          <view class="bubble-ai {{showInternalStatus && item.thinkingStatus && !item.renderableContent && !item.blocks.length && !(item.mcqCards && item.mcqCards.length) ? 'bubble-ai-thinking' : ''}}" wx:else>
            <!-- 思考中：独立状态面板 -->
          <view class="thinking-panel thinking-panel-{{item.thinkingTone ? item.thinkingTone : 'analyze'}}" wx:if="{{showInternalStatus && item.thinkingStatus && !item.renderableContent && !item.blocks.length && !(item.mcqCards && item.mcqCards.length)}}">
            <view class="thinking-rail"></view>
            <view class="thinking-main">
              <view class="thinking-head">
                <view class="thinking-badge thinking-badge-{{item.thinkingTone ? item.thinkingTone : 'analyze'}}">
                  <view class="dots-bounce"><view class="dot"></view><view class="dot"></view><view class="dot"></view></view>
                  <text class="thinking-badge-text">{{item.thinkingBadge ? item.thinkingBadge : 'AI 正在处理'}}</text>
                </view>
                <view class="thinking-scan thinking-scan-{{item.thinkingTone ? item.thinkingTone : 'analyze'}}"></view>
              </view>
              <text class="thinking-label">{{item.thinkingStatus}}</text>
              <text class="thinking-sub">{{item.thinkingSub}}</text>
              <view class="workflow-bar" wx:if="{{item.workflowMeta || item.workflowEntries.length}}">
                <text class="workflow-meta-text" wx:if="{{item.workflowMeta}}">{{item.workflowMeta}}</text>
                <view class="workflow-toggle" bindtap="onToggleWorkflowTrace" data-msgid="{{item.id}}" aria-role="button" aria-label="{{item.workflowExpanded ? '收起处理摘要' : '查看处理摘要'}}">
                  <text class="workflow-toggle-text">{{item.workflowExpanded ? '收起摘要' : (item.workflowToggleText || '查看处理摘要')}}</text>
                  <text class="workflow-toggle-arrow">{{item.workflowExpanded ? '⌃' : '⌄'}}</text>
                </view>
              </view>
              <view class="workflow-trace" wx:if="{{item.workflowExpanded && item.workflowEntries.length}}">
                <view class="workflow-step" wx:for="{{item.workflowEntries}}" wx:key="id" wx:for-item="wf">
                  <view class="workflow-step-head">
                    <text class="workflow-step-badge workflow-step-badge-{{wf.tone}}">{{wf.badge}}</text>
                    <text class="workflow-step-title">{{wf.title}}</text>
                  </view>
                  <text class="workflow-step-detail" wx:if="{{wf.detail}}">{{wf.detail}}</text>
                </view>
              </view>
            </view>
          </view>

          <!-- 思考中：生成阶段维持轻量提示 -->
          <view class="thinking thinking-inline" wx:elif="{{showInternalStatus && item.thinkingStatus && !(item.mcqCards && item.mcqCards.length) && !(item.workflowEntries.length && (item.renderableContent || item.blocks.length || (item.mcqCards && item.mcqCards.length)))}}">
            <view class="dots-bounce"><view class="dot"></view><view class="dot"></view><view class="dot"></view></view>
            <text class="thinking-label">{{item.thinkingStatus}}</text>
          </view>

          <view class="workflow-card workflow-card-{{item.workflowTone ? item.workflowTone : 'compose'}}" wx:if="{{showInternalStatus && item.workflowEntries.length && (item.renderableContent || item.blocks.length || (item.mcqCards && item.mcqCards.length))}}">
            <view class="workflow-card-head">
              <view class="workflow-card-title">
                <text class="workflow-card-badge">{{item.workflowBadge || '本轮推演'}}</text>
                <text class="workflow-card-label">{{item.workflowTitle || '处理摘要已完成'}}</text>
              </view>
              <view class="workflow-toggle workflow-toggle-inline" bindtap="onToggleWorkflowTrace" data-msgid="{{item.id}}" aria-role="button" aria-label="{{item.workflowExpanded ? '收起处理摘要' : '查看处理摘要'}}">
                <text class="workflow-toggle-text">{{item.workflowExpanded ? '收起摘要' : (item.workflowToggleText || '查看处理摘要')}}</text>
                <text class="workflow-toggle-arrow">{{item.workflowExpanded ? '⌃' : '⌄'}}</text>
              </view>
            </view>
            <text class="workflow-card-sub" wx:if="{{item.workflowSub}}">{{item.workflowSub}}</text>
            <text class="workflow-meta-text" wx:if="{{item.workflowMeta}}">{{item.workflowMeta}}</text>
            <text class="workflow-card-count" wx:if="{{item.workflowCountText}}">{{item.workflowCountText}}</text>
            <view class="workflow-trace workflow-trace-inline" wx:if="{{item.workflowExpanded && item.workflowEntries.length}}">
              <view class="workflow-step" wx:for="{{item.workflowEntries}}" wx:key="id" wx:for-item="wf">
                <view class="workflow-step-head">
                  <text class="workflow-step-badge workflow-step-badge-{{wf.tone}}">{{wf.badge}}</text>
                  <text class="workflow-step-title">{{wf.title}}</text>
                </view>
                <text class="workflow-step-detail" wx:if="{{wf.detail}}">{{wf.detail}}</text>
              </view>
            </view>
          </view>

          <!-- 结构化内容的正文说明，避免 table/formula 只挂在块里不显示 -->
          <text class="ai-text" user-select wx:if="{{item.hasStructuredContent && item.renderableContent}}">{{item.renderableContent}}</text>

          <!-- 纯文本回退：流式初期 blocks 尚未解析 -->
          <text class="ai-text" user-select wx:if="{{!item.hasStructuredContent && !item.blocks.length && (item.renderableContent || item.content)}}">{{item.renderableContent || item.content}}</text>

          <!-- Markdown 实时渲染（流式 + 完成态共用） -->
          <block wx:if="{{item.blocks.length}}">
            <block wx:for="{{item.blocks}}" wx:key="id" wx:for-item="b">

              <!-- 标题 -->
              <view class="md-h{{b.level}}" wx:if="{{b.type==='heading'}}">
                <rich-text class="md-richtext" user-select nodes="{{b.nodes}}"></rich-text>
              </view>

              <!-- 代码块 -->
              <view class="md-code" wx:elif="{{b.type==='code_block'}}">
                <text class="md-code-lang">{{b.language}}</text>
                <text class="md-code-body" user-select>{{b.content}}</text>
              </view>

              <!-- 水平线 -->
              <view class="md-hr" wx:elif="{{b.type==='hr'}}"></view>

              <!-- 结构化表格 -->
              <view wx:elif="{{b.type==='table' && b.isStructured}}">
                <text class="md-table-caption" wx:if="{{b.caption}}" selectable>{{b.caption}}</text>
                <text class="md-table-strategy" wx:if="{{b.mobileStrategy}}">手机端策略：{{b.mobileStrategy==='compact_cards' ? '紧凑卡片' : '横向滚动'}}</text>
                <view wx:if="{{b.mobileStrategy==='compact_cards'}}">
                  <view class="md-table-card" wx:for="{{b.rows}}" wx:key="index" wx:for-item="row" wx:for-index="rowIndex">
                    <text class="md-table-card-title" user-select>第{{rowIndex + 1}}行</text>
                    <view class="md-table-card-row" wx:for="{{b.headers}}" wx:key="index" wx:for-item="h" wx:for-index="colIndex">
                      <text class="md-table-card-key" user-select>{{h.text}}</text>
                      <text class="md-table-card-val" user-select>{{row[colIndex] ? row[colIndex].text : ''}}</text>
                    </view>
                  </view>
                </view>
                <scroll-view wx:else scroll-x class="md-table-scroll">
                  <view class="md-table">
                    <view class="md-thead">
                      <view class="md-th {{h.align==='center' ? 'md-align-center' : (h.align==='right' ? 'md-align-right' : 'md-align-left')}} {{h.highlight ? 'md-cell-highlight' : ''}}" wx:for="{{b.headers}}" wx:key="index" wx:for-item="h">
                        <text user-select class="{{h.highlight?'b':''}}">{{h.text}}</text>
                      </view>
                    </view>
                    <view class="md-tr" wx:for="{{b.rows}}" wx:key="index" wx:for-item="row">
                      <view class="md-td {{cell.align==='center' ? 'md-align-center' : (cell.align==='right' ? 'md-align-right' : 'md-align-left')}} {{cell.highlight ? 'md-cell-highlight' : ''}}" wx:for="{{row}}" wx:key="index" wx:for-item="cell">
                        <text user-select class="{{cell.highlight?'b':''}}">{{cell.text}}</text>
                      </view>
                    </view>
                  </view>
                </scroll-view>
              </view>

              <!-- Markdown 表格兜底 -->
              <scroll-view scroll-x wx:elif="{{b.type==='table'}}" class="md-table-scroll">
                <view class="md-table">
                  <view class="md-thead">
                  <view class="md-th" wx:for="{{b.headers}}" wx:key="index" wx:for-item="h">
                      <rich-text class="md-richtext" user-select nodes="{{h.nodes}}"></rich-text>
                    </view>
                  </view>
                  <view class="md-tr" wx:for="{{b.rows}}" wx:key="index" wx:for-item="row">
                    <view class="md-td" wx:for="{{row}}" wx:key="index" wx:for-item="cell">
                      <rich-text class="md-richtext" user-select nodes="{{cell.nodes}}"></rich-text>
                    </view>
                  </view>
                </view>
              </scroll-view>

              <!-- 引用块 -->
              <view class="md-blockquote" wx:elif="{{b.type==='blockquote'}}">
                <rich-text class="bq-line md-richtext" user-select wx:for="{{b.lineNodes}}" wx:key="index" wx:for-item="lineNodes" nodes="{{lineNodes}}"></rich-text>
              </view>

              <!-- 核心结论/注意/要点高亮 -->
              <view class="md-callout md-callout-{{b.variant}}" wx:elif="{{b.type==='callout'}}">
                <text class="callout-tag callout-tag-{{b.variant}}" user-select>{{b.label}}</text>
                <rich-text class="callout-body md-richtext" user-select wx:if="{{b.content.length}}" nodes="{{b.nodes}}"></rich-text>
              </view>

              <!-- 结构化公式 -->
              <view wx:elif="{{(b.type==='formula_block' || b.type==='formula_inline') && b.isStructured}}" class="md-formula {{b.type==='formula_inline' ? 'md-formula-inline' : ''}}">
                <text class="md-formula-label">{{b.type==='formula_inline' ? '行内公式' : '公式'}}</text>
                <image wx:if="{{b.svgUrl}}" class="md-formula-svg" src="{{b.svgUrl}}" mode="widthFix" show-menu-by-longpress />
                <text class="md-formula-text" selectable>{{b.displayText || b.latex || b.copyText}}</text>
                <text class="md-formula-copy" wx:if="{{b.copyText && b.copyText !== (b.displayText || b.latex)}}" selectable>{{b.copyText}}</text>
              </view>

              <!-- 教学步骤 -->
              <view class="md-steps" wx:elif="{{b.type==='steps' && b.isStructured}}">
                <text class="md-steps-title" user-select wx:if="{{b.title}}">{{b.title}}</text>
                <view class="md-step" wx:for="{{b.steps}}" wx:key="index" wx:for-item="step">
                  <text class="md-step-index" user-select>{{step.index}}.</text>
                  <view class="md-step-body">
                    <text class="md-step-name" user-select>{{step.title}}</text>
                    <text class="md-step-detail" user-select wx:if="{{step.detail}}">{{step.detail}}</text>
                  </view>
                </view>
              </view>

              <!-- 教学总结 -->
              <view class="md-recap" wx:elif="{{b.type==='recap' && b.isStructured}}">
                <text class="md-recap-title" user-select>{{b.title || '教学总结'}}</text>
                <text class="md-recap-summary" wx:if="{{b.summary}}" selectable>{{b.summary}}</text>
                <view wx:if="{{b.bullets && b.bullets.length}}">
                  <view class="md-recap-bullet" wx:for="{{b.bullets}}" wx:key="index" wx:for-item="bullet">
                    <text class="md-recap-bullet-mark">•</text>
                    <text class="md-recap-bullet-text" selectable>{{bullet}}</text>
                  </view>
                </view>
              </view>

              <!-- 图表数据卡 -->
              <view class="md-chart" wx:elif="{{b.type==='chart' && b.isStructured}}">
                <view class="md-chart-head">
                  <text class="md-chart-type">{{b.chartType}}</text>
                  <text class="md-chart-title" user-select wx:if="{{b.title}}">{{b.title}}</text>
                </view>
                <text class="md-chart-summary" wx:if="{{b.summary}}" selectable>{{b.summary}}</text>
                <view class="md-chart-series" wx:if="{{b.series && b.series.length}}">
                  <view class="md-chart-series-item" wx:for="{{b.series}}" wx:key="index" wx:for-item="series">
                    <text class="md-chart-series-name">{{series.name}}</text>
                    <text class="md-chart-series-summary" wx:if="{{series.summary}}" selectable>{{series.summary}}</text>
                  </view>
                </view>
                <view class="md-chart-axes" wx:if="{{b.axes && (b.axes.x || b.axes.y)}}">
                  <text class="md-chart-axis" user-select wx:if="{{b.axes.x}}">横轴：{{b.axes.x}}</text>
                  <text class="md-chart-axis" user-select wx:if="{{b.axes.y}}">纵轴：{{b.axes.y}}</text>
                </view>
                <text class="md-chart-caption" wx:if="{{b.caption}}" selectable>{{b.caption}}</text>
                <view wx:if="{{b.fallbackTable && b.fallbackTable.headers && b.fallbackTable.headers.length}}">
                  <text class="md-chart-fallback-title">fallback_table</text>
                  <text class="md-chart-strategy">图形不可用时回退为数据表</text>
                  <view wx:if="{{b.fallbackTable.mobileStrategy==='compact_cards'}}">
                    <view class="md-table-card" wx:for="{{b.fallbackTable.rows}}" wx:key="index" wx:for-item="row" wx:for-index="rowIndex">
                      <text class="md-table-card-title" user-select>第{{rowIndex + 1}}行</text>
                      <view class="md-table-card-row" wx:for="{{b.fallbackTable.headers}}" wx:key="index" wx:for-item="h" wx:for-index="colIndex">
                        <text class="md-table-card-key" user-select>{{h.text}}</text>
                        <text class="md-table-card-val" user-select>{{row[colIndex] ? row[colIndex].text : ''}}</text>
                      </view>
                    </view>
                  </view>
                  <scroll-view wx:else scroll-x class="md-table-scroll">
                    <view class="md-table">
                      <view class="md-thead">
                        <view class="md-th {{h.align==='center' ? 'md-align-center' : (h.align==='right' ? 'md-align-right' : 'md-align-left')}} {{h.highlight ? 'md-cell-highlight' : ''}}" wx:for="{{b.fallbackTable.headers}}" wx:key="index" wx:for-item="h">
                          <text user-select class="{{h.highlight?'b':''}}">{{h.text}}</text>
                        </view>
                      </view>
                      <view class="md-tr" wx:for="{{b.fallbackTable.rows}}" wx:key="index" wx:for-item="row">
                        <view class="md-td {{cell.align==='center' ? 'md-align-center' : (cell.align==='right' ? 'md-align-right' : 'md-align-left')}} {{cell.highlight ? 'md-cell-highlight' : ''}}" wx:for="{{row}}" wx:key="index" wx:for-item="cell">
                          <text user-select class="{{cell.highlight?'b':''}}">{{cell.text}}</text>
                        </view>
                      </view>
                    </view>
                  </scroll-view>
                </view>
              </view>

              <!-- 无序列表 -->
              <view class="md-ul" wx:elif="{{b.type==='ul'}}">
                <view class="md-li" wx:for="{{b.items}}" wx:key="index" wx:for-item="li">
                  <text class="bullet">·</text>
                  <view class="li-body">
                    <rich-text class="md-richtext md-richtext-inline" user-select nodes="{{li.nodes}}"></rich-text>
                  </view>
                </view>
              </view>

              <!-- 有序列表 -->
              <view class="md-ol" wx:elif="{{b.type==='ol'}}">
                <view class="md-li" wx:for="{{b.items}}" wx:key="index" wx:for-item="li">
                  <text class="ol-idx">{{li.index}}.</text>
                  <view class="li-body">
                    <rich-text class="md-richtext md-richtext-inline" user-select nodes="{{li.nodes}}"></rich-text>
                  </view>
                </view>
              </view>

              <!-- 空行 -->
              <view wx:elif="{{b.type==='blank'}}" style="height:12rpx"></view>

              <!-- 段落 -->
              <view class="md-p" wx:else>
                <block wx:if="{{b.schemaVersion===1 && b.text}}">
                  <text user-select>{{b.text}}</text>
                </block>
                <block wx:else>
                  <rich-text class="md-richtext" user-select nodes="{{b.nodes}}"></rich-text>
                </block>
              </view>

            </block>
	          </block>
	          <!-- 流式光标 -->
	          <view class="cursor" wx:if="{{item.streaming}}"></view>

          <!-- MCQ -->
          <view class="mcq" wx:if="{{item.mcqCards && item.mcqCards.length && (!item.streaming || (!item.renderableContent && !item.blocks.length))}}">
            <view class="mcq-head">
              <text class="mcq-head-title" user-select>{{item.mcqInteractiveReady ? '交互式作答' : '题目回看'}}</text>
              <text class="mcq-head-hint" user-select>{{item.mcqHint ? item.mcqHint : '点击选项后提交答案'}}</text>
            </view>
            <view class="mcq-card" wx:for="{{item.mcqCards}}" wx:key="index" wx:for-item="card">
              <view class="mcq-card-bar">
                <text class="mcq-card-index" user-select>第{{card.index}}题</text>
                <text class="mcq-card-type" user-select>{{card.questionType==='multi_choice' ? '多选题' : '单选题'}}</text>
              </view>
              <text class="mcq-stem" user-select>{{card.stem}}</text>
              <text class="mcq-hint" user-select wx:if="{{card.hint}}">提示：{{card.hint}}</text>
              <view
                class="mcq-opt {{o.selected?'sel':''}} {{!item.mcqInteractiveReady?'ro':''}}"
                wx:for="{{card.options}}" wx:key="key" wx:for-item="o"
                bindtap="onMcqTap" data-msgid="{{item.id}}" data-qindex="{{card.index}}" data-key="{{o.key}}"
                aria-role="button" aria-label="选项 {{o.key}}: {{o.text}}" aria-checked="{{o.selected}}"
              >
                <text class="mcq-key" user-select>{{o.key}}</text>
                <text class="mcq-val" user-select>{{o.text}}</text>
              </view>
            </view>
            <view wx:if="{{item.mcqInteractiveReady}}" class="mcq-submit" bindtap="onMcqSubmit" data-msgid="{{item.id}}" aria-role="button" aria-label="提交答案">
              <text class="mcq-submit-txt">提交答案</text>
            </view>
            <view wx:else class="mcq-submit disabled" aria-role="note" aria-label="当前题卡仅供查看">
              <text class="mcq-submit-txt">仅供查看</text>
            </view>
          </view>

          <!-- 引用 -->
          <view class="cite-list" wx:if="{{item.citations && item.citations.length}}">
            <text class="cite-head">参考来源</text>
            <view class="cite" wx:for="{{item.citations}}" wx:key="key" wx:for-item="ct">
              <text class="cite-key">[{{ct.key}}]</text>
              <view class="cite-body">
                <text class="cite-title">{{ct.title}}</text>
              </view>
            </view>
          </view>
        </view>
        <!-- AI 操作栏 — 气泡外部，左对齐 -->
        <view class="msg-actions msg-actions-left" wx:if="{{item.role !== 'user' && !item.streaming && (item.renderableContent || item.blocks.length || (item.mcqCards && item.mcqCards.length))}}">
          <view class="act-btn {{item.feedback==='up'?'act-on act-like':''}}" bindtap="onThumbUp" data-msgid="{{item.id}}" aria-role="button" aria-label="点赞">
            <view class="ico ico-thumbup"></view>
          </view>
          <view class="act-btn {{item.feedback==='down'?'act-on act-dislike':''}}" bindtap="onThumbDown" data-msgid="{{item.id}}" aria-role="button" aria-label="点踩">
            <view class="ico ico-thumbdown"></view>
          </view>
          <view class="act-sep"></view>
          <view class="act-btn" bindtap="onCopy" data-msgid="{{item.id}}" aria-role="button" aria-label="复制回答">
            <view class="ico ico-copy"></view>
          </view>
          <view class="act-btn" bindtap="onRetry" data-msgid="{{item.id}}" aria-role="button" aria-label="重新生成">
            <view class="ico ico-retry"></view>
          </view>
        </view>
        <!-- 反馈弹窗（点踩后展开） -->
        <view class="fb-popover" wx:if="{{feedbackMsgId === item.id}}">
          <view class="fb-header">
            <text class="fb-title">请告诉我们需要改进的地方：</text>
            <view class="fb-close" bindtap="onFeedbackClose" aria-role="button" aria-label="关闭反馈">
              <text class="fb-close-icon">×</text>
            </view>
          </view>
          <view class="fb-tags">
            <view class="fb-tag {{feedbackTag.has(feedbackTags, '事实错误')?'on':''}}" catchtap="onFeedbackTag" data-tag="事实错误" aria-role="button" aria-label="反馈：事实错误">
              <text class="fb-tag-txt">❌ 事实错误</text>
            </view>
            <view class="fb-tag {{feedbackTag.has(feedbackTags, '产生幻觉')?'on':''}}" catchtap="onFeedbackTag" data-tag="产生幻觉" aria-role="button" aria-label="反馈：产生幻觉">
              <text class="fb-tag-txt">🤥 产生幻觉</text>
            </view>
            <view class="fb-tag {{feedbackTag.has(feedbackTags, '逻辑不通')?'on':''}}" catchtap="onFeedbackTag" data-tag="逻辑不通" aria-role="button" aria-label="反馈：逻辑不通">
              <text class="fb-tag-txt">📉 逻辑不通</text>
            </view>
            <view class="fb-tag {{feedbackTag.has(feedbackTags, '格式混乱')?'on':''}}" catchtap="onFeedbackTag" data-tag="格式混乱" aria-role="button" aria-label="反馈：格式混乱">
              <text class="fb-tag-txt">📝 格式混乱</text>
            </view>
          </view>
          <input class="fb-input" placeholder="更多细节（可选）..." value="{{feedbackComment}}" bindinput="onFeedbackInput" maxlength="500" />
          <view class="fb-submit {{feedbackSubmitting ? 'fb-submit-disabled' : ''}}" catchtap="onFeedbackSubmit" aria-role="button" aria-label="提交反馈">
            <text class="fb-submit-txt">{{feedbackSubmitting ? '提交中...' : '提交反馈'}}</text>
          </view>
        </view>
      </view>
      <view id="msg-bottom" style="height:{{chatBottomSpacer}}px"></view>
    </view>
  </scroll-view>

  <!-- 底部输入（仅 Chat 状态） -->
  <view class="bottom-bar" wx:if="{{hasMessages}}" style="{{bottomBarStyle}}">
    <view class="bottom-input-card">
      <textarea
        class="input-field"
        value="{{inputText}}"
        bindinput="onInput"
        bindconfirm="sendMessage"
        placeholder="继续追问..."
        placeholder-class="input-ph"
        auto-height
        maxlength="2000"
        confirm-type="send"
        show-confirm-bar="{{false}}"
        adjust-position="{{true}}"
        cursor-spacing="{{inputCursorSpacing}}"
        bindfocus="onKeyboardFocus"
        bindblur="onKeyboardBlur"
      />
	      <view class="input-bottom">
	        <view class="mode-row">
	          <view class="mode-pill {{answerMode==='AUTO'?'on':''}}" bindtap="onMode" data-m="AUTO"><text class="mode-pill-txt">智能</text></view>
	          <view class="mode-pill {{answerMode==='DEEP'?'on':''}}" bindtap="onMode" data-m="DEEP"><text class="mode-pill-txt">深度</text></view>
	          <view class="mode-pill {{answerMode==='FAST'?'on':''}}" bindtap="onMode" data-m="FAST"><text class="mode-pill-txt">快速</text></view>
	          <text class="mode-hint">自动切换 · 1-10点</text>
	        </view>
	        <view class="send-btn {{isStreaming ? 'stop' : (inputText ? 'on' : '')}}" bindtap="{{isStreaming ? 'stopStream' : 'sendMessage'}}" aria-role="button" aria-label="{{isStreaming ? '停止生成' : '发送消息'}}">
	          <text class="send-icon">{{isStreaming ? '■' : '▶'}}</text>
	        </view>
	      </view>
	      <view class="tool-row">
	        <view class="tool-chip {{enableReason ? 'on' : ''}}" bindtap="onToggleReason" aria-role="button" aria-label="{{enableReason ? '关闭推理' : '开启推理'}}">
	          <text class="tool-chip-icon">◎</text>
	          <text class="tool-chip-txt">推理</text>
	        </view>
	        <text class="tool-hint">知识库检索默认自动开启，联网搜索暂未开放</text>
	      </view>
	    </view>
	  </view>

  <!-- ★ 积分明细半屏弹窗 -->
  <view class="billing-mask {{billingShow ? 'show' : ''}}" bindtap="closeBilling"></view>
  <view class="billing-drawer {{billingShow ? 'show' : ''}}">
    <view class="billing-header">
      <text class="billing-title">积分明细</text>
      <view class="billing-close" bindtap="closeBilling" aria-role="button" aria-label="关闭">
        <text class="billing-close-icon">×</text>
      </view>
    </view>
    <!-- 余额 -->
    <view class="billing-balance">
      <text class="billing-bal-star">✦</text>
      <text class="billing-bal-num">{{billingBalance}}</text>
      <text class="billing-bal-label">当前余额</text>
    </view>
    <!-- 流水 -->
    <scroll-view class="billing-list" scroll-y>
      <view wx:if="{{billingLoading}}" class="billing-empty">
        <text class="billing-empty-txt">加载中...</text>
      </view>
      <view wx:elif="{{billingEntries.length === 0}}" class="billing-empty">
        <text class="billing-empty-txt">暂无消费记录</text>
      </view>
      <view wx:else>
        <view class="billing-item" wx:for="{{billingEntries}}" wx:key="id">
          <view class="billing-item-left">
            <text class="billing-item-reason">{{item.reason}}</text>
            <text class="billing-item-time">{{item.time}}</text>
          </view>
          <view class="billing-item-right">
            <text class="billing-item-delta {{item.isDebit ? 'debit' : 'credit'}}">{{item.isDebit ? '' : '+'}}{{item.delta}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

</view>
