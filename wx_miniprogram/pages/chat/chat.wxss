.page.light .workflow-step-raw-text { color: #42536c; }
.page.light .workflow-card {
  background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(244,248,255,0.96) 100%);
  border-color: #d8e5fb;
}
.page.light .workflow-card-label { color: #1f2d45; }
.page.light .workflow-card-badge { color: #2f6bff; }
.page.light .workflow-card-sub { color: #47668f; }
.page.light .workflow-card-count { color: #6b7a90; }
.page.light .dots-bounce .dot { background: #5e8cff; }
.page.light .cursor { background: #2f6bff; }

/* ── Logo ──────────────────────────────────── */
.page.light .nav-logo { filter: brightness(0); }
.page.light .nav-brand { color: #132036; }

/* ── 积分明细弹窗 ──────────────────────────── */
.page.light .billing-drawer {
  background: #f9fbff; border-color: #dbe6f5;
}
.page.light .billing-title { color: #111827; }
.page.light .billing-close { background: #eef4ff; }
.page.light .billing-close-icon { color: #7b8da8; }
.page.light .billing-bal-num { color: #111827; }
.page.light .billing-bal-label { color: #8b98ad; }
.page.light .billing-list { border-color: #e6edf8; }
.page.light .billing-empty-txt { color: #8b98ad; }
.page.light .billing-item { border-color: #edf2fb; }
.page.light .billing-item-reason { color: #334155; }
.page.light .billing-item-time { color: #8b98ad; }

/* ═══════════════════════════════════════════════
   ★ 低端设备降级 — 关闭动画、减少 GPU 负载
   ═══════════════════════════════════════════════ */

/* 消息入场动画关闭 */
.msg.no-anim.user { animation: none; }
.msg.no-anim.ai { animation: none; }

/* 焦点脉冲关闭 */
.focus-bar.no-pulse::after { animation: none; opacity: 0.4; }

/* 低端静态网格（替代跑马灯） */
.example-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  padding: 0 36rpx 8rpx;
}
.example-grid .example-card {
  flex: 0 0 calc(50% - 8rpx); width: calc(50% - 8rpx);
  opacity: 1; animation: none;
}
