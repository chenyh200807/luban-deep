.billing-bal-label { font-size: 24rpx; color: rgba(255,255,255,0.4); align-self: flex-end; margin-bottom: 8rpx; }

.billing-list {
  flex: 1; overflow-y: auto;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}

.billing-empty {
  padding: 80rpx 0; text-align: center;
}
.billing-empty-txt { font-size: 26rpx; color: rgba(255,255,255,0.4); }

.billing-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}
