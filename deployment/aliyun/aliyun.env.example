# DeepTutor on Aliyun ECS (8.135.42.145)
# Copy this file to /root/deeptutor/.env on the server and fill in the secrets.

# Ports
BACKEND_PORT=8001
FRONTEND_PORT=3782

# Runtime environment
SERVICE_ENV=production
APP_ENV=production
DEEPTUTOR_ENV=production

# Release lineage
# scripts/sync_to_aliyun.sh rewrites release id and git sha from the local release commit.
DEEPTUTOR_SERVICE_VERSION=1.0.0
DEEPTUTOR_RELEASE_ID=
DEEPTUTOR_GIT_SHA=
DEEPTUTOR_PROMPT_VERSION=unset
DEEPTUTOR_FF_SNAPSHOT_HASH=

# Public API URL for browser-side requests.
# If you later bind a domain to the API, replace this with that domain.
NEXT_PUBLIC_API_BASE_EXTERNAL=http://8.135.42.145:8001
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_BI_API_TOKEN=

# LLM
LLM_BINDING=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=
LLM_HOST=https://api.deepseek.com/v1
LLM_API_VERSION=
LLM_FALLBACK_BINDING=dashscope
LLM_FALLBACK_MODEL=qwen3.6-flash
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_FALLBACK_API_VERSION=

# Embedding
EMBEDDING_BINDING=dashscope
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_KEY=
EMBEDDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_DIMENSION=1024
EMBEDDING_API_VERSION=

# Optional search
SEARCH_PROVIDER=
SEARCH_API_KEY=
SEARCH_BASE_URL=

# Optional branding
APP_BRAND_NAME=DeepTutor
NEXT_PUBLIC_APP_BRAND_NAME=DeepTutor

# Mini Program / SMS
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=
DEEPTUTOR_AUTH_SECRET=
DEEPTUTOR_ADMIN_USER_IDS=
MEMBER_CONSOLE_USE_REAL_SMS=true
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# SSL / networking
DISABLE_SSL_VERIFY=false

# Build acceleration on Aliyun
APT_MIRROR=https://mirrors.aliyun.com/debian
SECURITY_MIRROR=https://mirrors.aliyun.com/debian-security
RUSTUP_DIST_SERVER=https://rsproxy.cn
RUSTUP_UPDATE_ROOT=https://rsproxy.cn/rustup
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
PIP_EXTRA_INDEX_URL=

# Observability
# Dedicated read-only token for /metrics and /metrics/prometheus scraping.
DEEPTUTOR_METRICS_TOKEN=

# When sharing the existing /root/luban Langfuse stack, use:
#   LANGFUSE_ENABLED=true
#   LANGFUSE_BASE_URL=http://jgzk-langfuse:3000
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
LANGFUSE_HTTPX_TRUST_ENV=false
LANGFUSE_TRACING_ENVIRONMENT=production

# Optional Bailian Prometheus reconciliation
# Example base URL:
# https://aliyun-product-data-xxxx-cn-beijing.cn-beijing.log.aliyuncs.com/prometheus/aliyun-product-data-xxxx-cn-beijing/bailian-model-metrics
BAILIAN_TELEMETRY_BASE_URL=
BAILIAN_TELEMETRY_ACCESS_KEY_ID=
BAILIAN_TELEMETRY_ACCESS_KEY_SECRET=
BAILIAN_TELEMETRY_WORKSPACE_ID=
BAILIAN_TELEMETRY_APIKEY_ID=
BAILIAN_TELEMETRY_TIMEOUT_S=15
BAILIAN_TELEMETRY_VERIFY_SSL=true

# Optional Bailian official billing reconciliation (BssOpenApi)
# Defaults match Bailian pay-as-you-go inference in the China site billing center.
BAILIAN_BILLING_ACCESS_KEY_ID=
BAILIAN_BILLING_ACCESS_KEY_SECRET=
BAILIAN_BILLING_ENDPOINT=business.aliyuncs.com
BAILIAN_BILLING_REGION_ID=cn-hangzhou
BAILIAN_BILLING_PRODUCT_CODE=sfm
BAILIAN_BILLING_PRODUCT_TYPE=sfm_inference_public_cn
BAILIAN_BILLING_WORKSPACE_ID=
BAILIAN_BILLING_APIKEY_ID=
BAILIAN_BILLING_MAX_RESULTS=100

# Optional Supabase-based settings
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_RAG_ENABLED=false
